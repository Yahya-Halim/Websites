---
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

const title = `Visit Us | ${business?.name ?? "Captain's Fish & Chicken"}`;
const description = `Visit ${business?.name} at ${business?.address?.street}, ${business?.address?.city}, ${business?.address?.state}. Open ${business?.hours?.displayText ?? 'Mon–Sun 11am–10pm'}.`;
---

<Base title={title} description={description}>
  <section class="visit-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Visit Us</h1>
      <p class="tagline">{business?.address?.street} — {business?.address?.city}, {business?.address?.state}</p>
    </div>
  </section>

  <div class="wave-divider">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path fill="#F6F7F9" d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z"></path>
    </svg>
  </div>

  <section class="section section-light">
    <div class="container">
      <div class="visit-grid">
        <!-- Address Card -->
        <div class="info-card">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 5-9 13-9 13S3 15 3 10a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h3>Address</h3>
          <address class="address-block">
            {business?.name}<br />
            {business?.address?.street}<br />
            {business?.address?.city}, {business?.address?.state} {business?.address?.zip}
          </address>
          <a href={business?.directionsUrl} class="btn btn-primary" target="_blank" rel="noopener">Get Directions</a>
        </div>

        <!-- Hours Card -->
        <div class="info-card">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <h3>Hours</h3>
          <ul class="hours-list">
            <li><span>Mon–Thu</span> <span>11:00 AM – 10:00 PM</span></li>
            <li><span>Fri–Sat</span> <span>11:00 AM – 11:00 PM</span></li>
            <li><span>Sunday</span> <span>11:00 AM – 8:00 PM</span></li>
          </ul>
        </div>

        <!-- Contact Card -->
        <div class="info-card">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <h3>Contact</h3>
          <div class="contact-lines">
            <p><a href={`tel:${business?.phone}`}>{business?.phone}</a></p>
            <p><a href={`mailto:${business?.email}`}>{business?.email}</a></p>
          </div>
          <div class="social-links">
            <a href={business?.sameAs?.[0]} class="social-link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Follow on Facebook
            </a>
          </div>
        </div>

        <!-- Order Online Card -->
        <div class="info-card">
          <div class="info-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <path d="M3 6h18"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
          </div>
          <h3>Order Online</h3>
          <p class="order-text">Pickup or delivery. Your food comes out hot, crispy, and exactly how you ordered it.</p>
          <div class="order-links">
            <a href={business?.sameAs?.[1]} class="btn btn-primary btn-delivery" target="_blank" rel="noopener">
              <svg class="delivery-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
                <path d="M15 5h-2l-1 2H9L7 9H4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h1a3 3 0 0 0 6 0h2a3 3 0 0 0 6 0h1a2 2 0 0 0 2-2v-5a2 2 0 0 0-2-2h-3l-2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                <circle cx="7" cy="17" r="2" fill="currentColor"/>
                <circle cx="17" cy="17" r="2" fill="currentColor"/>
              </svg>
              UberEats
            </a>
            <a href={business?.sameAs?.[2]} class="btn btn-secondary btn-delivery" target="_blank" rel="noopener">
              <svg class="delivery-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
                <path d="M12 3l9 4.5v6L12 18 3 13.5v-6L12 3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                <path d="M12 12l9-4.5M12 12v6M12 12L3 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              DoorDash
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="map-section-header">
        <h2>Find Us</h2>
        <p>{business?.address?.street}, {business?.address?.city}, {business?.address?.state} {business?.address?.zip}</p>
      </div>
      <div class="map-wrapper">
        <iframe
          title="Captain's Fish and Chicken location"
          src={`https://maps.google.com/maps?q=${encodeURIComponent(`${business?.address?.street},${business?.address?.city},${business?.address?.state} ${business?.address?.zip}`)}&output=embed`}
          width="100%"
          height="420"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <p class="map-fallback">
        <a href={business?.mapsUrl} target="_blank" rel="noopener">Open in Google Maps →</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .visit-hero {
    min-height: 45vh;
    background: linear-gradient(180deg, #112E5C, #08162B);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 8rem 2rem 4rem;
    text-align: center;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(8, 22, 43, 0.4);
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  .visit-hero h1 {
    color: var(--white);
    font-size: clamp(2.5rem, 6vw, 4rem);
    text-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .tagline {
    color: var(--gold);
    font-size: 1.15rem;
    font-weight: 500;
  }
  .wave-divider { margin-top: -1px; }
  .wave-divider svg { display: block; }

  .visit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .info-card {
    background: var(--white);
    border-radius: 20px;
    padding: 2rem 1.75rem;
    box-shadow: var(--shadow-small);
    border: 1px solid rgba(191, 200, 214, 0.25);
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .info-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-medium);
  }
  .info-icon {
    color: var(--navy);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: var(--light-gray);
    margin-bottom: 1rem;
  }
  .info-card h3 {
    color: var(--navy);
    font-size: 1.15rem;
    margin-bottom: 1rem;
  }
  .address-block {
    font-style: normal;
    font-size: 1rem;
    color: #444;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .hours-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
  }
  .hours-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.65rem 0;
    border-bottom: 1px dashed var(--silver);
    color: #444;
    font-size: 0.95rem;
  }
  .hours-list li:last-child {
    border-bottom: none;
  }
  .contact-lines {
    margin-bottom: 1rem;
  }
  .contact-lines p {
    margin: 0.4rem 0;
    font-size: 0.95rem;
  }
  .contact-lines a {
    color: var(--ocean);
    font-weight: 500;
  }
  .contact-lines a:hover {
    color: var(--gold);
  }
  .social-links {
    margin-top: 0.75rem;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #3b5998;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    background: rgba(59, 89, 152, 0.08);
    transition: background 0.2s ease;
  }
  .social-link:hover {
    background: rgba(59, 89, 152, 0.15);
  }
  .social-link svg {
    flex-shrink: 0;
  }
  .order-text {
    font-size: 0.95rem;
    color: #666;
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .order-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn-delivery {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .delivery-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
  }

  .map-section-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .map-section-header h2 {
    color: var(--navy);
    font-size: 1.8rem;
  }
  .map-section-header p {
    color: #666;
    font-size: 1rem;
    margin-top: 0.4rem;
  }
  .map-wrapper {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow-large);
    line-height: 0;
  }
  .map-wrapper iframe {
    display: block;
  }
  .map-fallback {
    margin-top: 1rem;
    text-align: center;
  }
  .map-fallback a {
    color: var(--ocean);
    font-weight: 600;
  }
  .map-fallback a:hover {
    color: var(--gold);
  }

  @media (max-width: 640px) {
    .visit-hero { padding: 6rem 1rem 3rem; }
    .visit-grid { grid-template-columns: 1fr; }
    .info-card { padding: 1.5rem 1.25rem; }
    .map-wrapper iframe { height: 300px; }
  }
</style>
