---
import { getEntry } from 'astro:content';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
const businessName = business && business.name ? business.name : "Captain's Fish & Chicken";
const logoAlt = business?.brand?.logoAlt ?? `${businessName} logo`;
const siteEntry = await getEntry('site', 'site');
const site = siteEntry?.data;
---

<header class={`site-header ${transparent ? 'transparent' : 'solid'}`} data-transparent={transparent}>
  <div class="header-inner">
    <a href="/" class="brand" aria-label={`${businessName} — home`}>
      <span class="logo-chip">
        <img src="/logo.png" alt={logoAlt} class="nav-logo" width="48" height="48" />
      </span>
    </a>

    {site?.nav && (
      <nav class="primary-nav" aria-label="Primary">
        <ul>
          {site.nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
    )}

    <div class="header-actions">
      {site?.cta && (
        <a class="cta-btn" href={site.cta.href} target="_blank" rel="noopener">{site.cta.text}</a>
      )}
      <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  {site?.nav && (
    <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile">
      <ul>
        {site.nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
        {site?.cta && (
          <li><a class="mobile-cta" href={site.cta.href} target="_blank" rel="noopener">{site.cta.text}</a></li>
        )}
      </ul>
    </nav>
  )}
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: background var(--transition-smooth), box-shadow var(--transition-smooth);
  }
  .site-header.transparent {
    background: transparent;
  }
  .site-header.solid {
    background: var(--navy);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.75rem 1.5rem;
  }

  /* Brand / logo */
  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    transition: transform var(--transition-smooth);
  }
  .brand:hover .logo-chip {
    transform: scale(1.05);
  }
  .nav-logo {
    width: 52px;
    height: 52px;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 3px 8px rgba(0, 0, 0, 0.45));
  }

  /* Desktop nav */
  .primary-nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }
  .primary-nav a {
    text-decoration: none;
    color: var(--white);
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: color var(--transition-fast);
    position: relative;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.35);
  }
  .primary-nav a::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gold);
    transition: width var(--transition-fast);
  }
  .primary-nav a:hover { color: var(--gold); }
  .primary-nav a:hover::after { width: 100%; }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .cta-btn {
    background: var(--gold);
    color: var(--navy);
    padding: 0.7rem 1.5rem;
    border-radius: 14px;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
    box-shadow: var(--shadow-btn);
    transition: all var(--transition-smooth);
  }
  .cta-btn:hover {
    background: var(--gold-bright);
    transform: scale(1.05);
    box-shadow: 0 12px 35px rgba(245, 181, 30, 0.35);
  }

  /* Hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0 9px;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    height: 3px;
    width: 100%;
    background: var(--white);
    border-radius: 2px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }
  .site-header.menu-open .nav-toggle span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  .site-header.menu-open .nav-toggle span:nth-child(2) { opacity: 0; }
  .site-header.menu-open .nav-toggle span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

  /* Mobile nav drawer */
  .mobile-nav {
    display: none;
    background: var(--navy-dark);
    border-top: 2px solid var(--gold);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
  }
  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 0.5rem 1.5rem 1.25rem;
  }
  .mobile-nav li { border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
  .mobile-nav li:last-child { border-bottom: none; }
  .mobile-nav a {
    display: block;
    padding: 0.95rem 0.25rem;
    color: var(--white);
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .mobile-nav a:hover { color: var(--gold); }
  .mobile-nav .mobile-cta {
    margin-top: 0.75rem;
    background: var(--gold);
    color: var(--navy);
    border-radius: 14px;
    text-align: center;
    font-weight: 700;
  }
  .site-header.menu-open .mobile-nav { display: block; }

  @media (max-width: 860px) {
    .primary-nav { display: none; }
    .nav-toggle { display: flex; }
    .cta-btn { display: none; }
    /* When the drawer is open on the home hero, give the bar a solid backdrop */
    .site-header.menu-open.transparent { background: var(--navy); }
  }
  @media (max-width: 420px) {
    .header-inner { padding: 0.6rem 1rem; }
  }
</style>

<script>
  // Sticky header: transparent over the hero, solid navy after scrolling.
  const header = document.querySelector('.site-header');
  if (header) {
    const startsTransparent = header.getAttribute('data-transparent') === 'true';
    const onScroll = () => {
      if (!startsTransparent) return; // non-home pages stay solid
      if (window.scrollY > 40) {
        header.classList.remove('transparent');
        header.classList.add('solid');
      } else if (!header.classList.contains('menu-open')) {
        header.classList.add('transparent');
        header.classList.remove('solid');
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // Mobile menu toggle
    const toggle = header.querySelector('.nav-toggle');
    const mobileNav = header.querySelector('.mobile-nav');
    const setMenu = (open) => {
      header.classList.toggle('menu-open', open);
      toggle?.setAttribute('aria-expanded', String(open));
      toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      if (open) {
        mobileNav?.querySelector('a')?.focus();
      } else {
        onScroll();
      }
    };
    toggle?.addEventListener('click', () =>
      setMenu(!header.classList.contains('menu-open')),
    );
    // Close the drawer when a link is tapped
    header.querySelectorAll('.mobile-nav a').forEach((link) =>
      link.addEventListener('click', () => setMenu(false)),
    );
    // Close on Escape and return focus to the toggle
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.classList.contains('menu-open')) {
        setMenu(false);
        toggle?.focus();
      }
    });
  }
</script>
