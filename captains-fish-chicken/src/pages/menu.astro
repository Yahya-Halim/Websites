---
import Base from '../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

const menuSections = await getCollection('menu');
const sorted = menuSections.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const title = `Menu | ${business?.name ?? "Captain's Fish & Chicken"}`;
const description = `Full menu for ${business?.name}. Seafood, chicken, combos, and sides in Cedar Rapids.`;
---

<Base title={title} description={description}>
  <section class="menu-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Our Menu</h1>
      <p class="tagline">Hand-breaded fish, crispy chicken, and all the sides that make a dinner complete.</p>
    </div>
  </section>

  <div class="wave-divider">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path fill="#FFFFFF" d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z"></path>
    </svg>
  </div>

  <section class="section menu-page">
    <div class="menu-layout">
      <!-- Desktop Sidebar (hidden on mobile) -->
      <aside class="menu-sidebar">
        <div class="sidebar-inner">
          <h3 class="sidebar-title">Categories</h3>
          <nav class="filter-nav" aria-label="Menu categories">
            <button class="filter-btn active" data-filter="all">
              <span>All Items</span>
              <span class="count">{sorted.reduce((acc, s) => acc + s.data.items.length, 0)}</span>
            </button>
            {sorted.map((section) => (
              <button class="filter-btn" data-filter={section.data.slug}>
                <span>{section.data.name}</span>
                <span class="count">{section.data.items.length}</span>
              </button>
            ))}
          </nav>
        </div>
      </aside>

      <!-- Mobile Filter Button (above menu content) -->
      <button class="filter-toggle" id="filter-toggle" aria-label="Open menu categories" aria-controls="filter-popup" aria-expanded="false">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 3H2l8 9.46V19l4 2v-8.54z"/>
        </svg>
        Filter Categories
      </button>

      <!-- Mobile Filter Popup (slide-up drawer) -->
      <div class="filter-backdrop" id="filter-backdrop" aria-hidden="true"></div>
      <div class="filter-popup" id="filter-popup" role="dialog" aria-label="Menu categories" aria-modal="true">
        <div class="filter-popup-header">
          <h3>Select a Category</h3>
          <button class="filter-popup-close" id="filter-popup-close" aria-label="Close categories">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <nav class="filter-nav" aria-label="Menu categories">
          <button class="filter-btn active" data-filter="all">
            <span>All Items</span>
            <span class="count">{sorted.reduce((acc, s) => acc + s.data.items.length, 0)}</span>
          </button>
          {sorted.map((section) => (
            <button class="filter-btn" data-filter={section.data.slug}>
              <span>{section.data.name}</span>
              <span class="count">{section.data.items.length}</span>
            </button>
          ))}
        </nav>
      </div>

      <!-- Main Content -->
      <div class="menu-content">
        {sorted.map((section) => (
          <div class="menu-section" data-category={section.data.slug}>
            <div class="section-header">
              <h2>{section.data.name}</h2>
              <p class="section-desc">{section.data.description}</p>
            </div>
            <div class="items">
              {section.data.items.map((item) => (
                <div class="item-card">
                  <div class="item-image">
                    {item.image ? (
                      <img src={item.image} alt={item.imageAlt || item.name} loading="lazy" />
                    ) : (
                      <div class="image-placeholder">
                        <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" aria-hidden="true">
                          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                        </svg>
                      </div>
                    )}
                  </div>
                  <div class="item-body">
                    <div class="item-header">
                      <div class="item-title-wrap">
                        <h3>{item.name}</h3>
                        {item.popular && (
                          <span class="popular-badge">
                            <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
                            Popular
                          </span>
                        )}
                      </div>
                      <div class="prices">
                        {item.prices.map((p) => (
                          <span class="price-tag">
                            {p.label && p.label !== '' && p.label !== 'Regular' ? `${p.label}: ` : ''}
                            <strong>${p.price.toFixed(2)}</strong>
                          </span>
                        ))}
                      </div>
                    </div>
                    <p class="item-desc">{item.description}</p>
                    {item.rating && (
                      <span class="rating">
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
                        {item.rating}
                      </span>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
        <p class="price-note">
          Everything is fried fresh to order — nothing sits under a heat lamp. Prices are updated regularly but may
          change. Call us at <a href={`tel:${business?.phone}`}>{business?.phone}</a>
          or check UberEats / DoorDash to confirm current pricing.
        </p>
      </div>
    </div>
  </section>

  <section class="section section-navy">
    <div class="container">
      <div class="section-header">
        <h2>Order Online</h2>
        <p>Skip the line. Order ahead. Get your food delivered or ready for pickup — hot, crispy, and exactly how you ordered it.</p>
      </div>
      <div class="order-links">
        <a href={business?.sameAs?.[1]} class="btn btn-primary btn-delivery" target="_blank" rel="noopener">
          <svg class="delivery-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
            <path d="M15 5h-2l-1 2H9L7 9H4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h1a3 3 0 0 0 6 0h2a3 3 0 0 0 6 0h1a2 2 0 0 0 2-2v-5a2 2 0 0 0-2-2h-3l-2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="7" cy="17" r="2" fill="currentColor"/>
            <circle cx="17" cy="17" r="2" fill="currentColor"/>
          </svg>
          UberEats
        </a>
        <a href={business?.sameAs?.[2]} class="btn btn-secondary btn-delivery" target="_blank" rel="noopener">
          <svg class="delivery-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
            <path d="M12 3l9 4.5v6L12 18 3 13.5v-6L12 3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <path d="M12 12l9-4.5M12 12v6M12 12L3 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          DoorDash
        </a>
      </div>
    </div>
  </section>

  <script>
    (function() {
      const buttons = document.querySelectorAll('.filter-btn');
      const sections = document.querySelectorAll('.menu-section');
      const toggle = document.getElementById('filter-toggle');
      const popup = document.getElementById('filter-popup');
      const backdrop = document.getElementById('filter-backdrop');
      const closeBtn = document.getElementById('filter-popup-close');

      function openPopup() {
        if (!popup || !backdrop || !toggle) return;
        popup.classList.add('active');
        backdrop.classList.add('active');
        toggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closePopup() {
        if (!popup || !backdrop || !toggle) return;
        popup.classList.remove('active');
        backdrop.classList.remove('active');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      if (toggle) toggle.addEventListener('click', openPopup);
      if (closeBtn) closeBtn.addEventListener('click', closePopup);
      if (backdrop) backdrop.addEventListener('click', closePopup);

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && popup && popup.classList.contains('active')) {
          closePopup();
        }
      });

      // Filter click
      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          const filter = btn.dataset.filter;

          buttons.forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');

          sections.forEach(function(section) {
            if (filter === 'all' || section.dataset.category === filter) {
              section.style.display = '';
              section.style.animation = 'fadeIn 0.4s ease';
            } else {
              section.style.display = 'none';
            }
          });

          // Close popup if a filter was clicked inside it
          if (popup && popup.classList.contains('active') && btn.closest('.filter-popup')) {
            closePopup();
          }
        });
      });
    })();
  </script>
</Base>

<style>
  .menu-hero {
    min-height: 50vh;
    background: linear-gradient(180deg, #112E5C, #08162B);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 8rem 2rem 4rem;
    text-align: center;
  }
  .hero-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(8, 22, 43, 0.4);
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  .menu-hero h1 {
    color: var(--white);
    font-size: clamp(2.5rem, 6vw, 4rem);
    text-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .tagline {
    color: var(--gold);
    font-size: 1.2rem;
    font-weight: 500;
  }
  .wave-divider { margin-top: -1px; }
  .wave-divider svg { display: block; }

  /* Menu Layout */
  .menu-page {
    padding: 3rem 0;
  }
  .menu-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  /* Sidebar */
  .menu-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: relative;
  }
  .sidebar-inner {
    position: sticky;
    top: 100px;
  }
  .sidebar-title {
    font-family: 'Poppins', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--navy);
    margin-bottom: 1rem;
  }
  .filter-nav {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .filter-btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.65rem 0.9rem;
    border: none;
    border-radius: 12px;
    background: transparent;
    color: #555;
    font-family: 'Poppins', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
  }
  .filter-btn:hover {
    background: var(--light-gray);
    color: var(--navy);
  }
  .filter-btn.active {
    background: var(--navy);
    color: var(--white);
    box-shadow: 0 4px 12px rgba(11, 31, 58, 0.2);
  }
  .filter-btn .count {
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(0,0,0,0.08);
    padding: 0.15rem 0.5rem;
    border-radius: 50px;
    min-width: 24px;
    text-align: center;
  }
  .filter-btn.active .count {
    background: var(--gold);
    color: var(--navy);
  }

  /* Main Content */
  .menu-content {
    flex: 1;
    min-width: 0;
  }
  .menu-section {
    margin-bottom: 3rem;
  }
  .menu-section .section-header {
    margin-bottom: 1.5rem;
  }
  .menu-section .section-header h2 {
    font-size: 1.6rem;
    color: var(--navy);
    position: relative;
    display: inline-block;
  }
  .menu-section .section-header h2::after {
    content: '';
    display: block;
    width: 50px;
    height: 3px;
    background: var(--gold);
    margin-top: 0.4rem;
    border-radius: 2px;
  }
  .section-desc {
    color: #666;
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  /* Items List */
  .items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .item-card {
    display: flex;
    flex-direction: row;
    background: var(--white);
    border-radius: 16px;
    box-shadow: var(--shadow-small);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid rgba(191, 200, 214, 0.25);
    overflow: hidden;
  }
  .item-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-medium);
  }
  .item-image {
    width: 160px;
    min-height: 130px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }
  .item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 130px;
    background: linear-gradient(135deg, #0B1F3A, #1a3a66);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
  }
  .item-body {
    padding: 1.25rem;
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .item-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .item-title-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .item-header h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--navy);
    text-transform: none;
    letter-spacing: 0;
    margin: 0;
    line-height: 1.3;
  }
  .popular-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--gold);
    color: var(--navy);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 0.2rem 0.5rem;
    border-radius: 50px;
    flex-shrink: 0;
  }
  .prices {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  .price-tag {
    font-size: 0.8rem;
    color: #555;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .price-tag strong {
    background: var(--gold);
    color: var(--navy);
    font-size: 0.9rem;
    padding: 0.1rem 0.5rem;
    border-radius: 8px;
    font-weight: 700;
  }
  .item-desc {
    color: #777;
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }
  .rating {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: var(--gold);
    font-weight: 600;
  }
  .rating svg {
    flex-shrink: 0;
  }

  .price-note {
    margin-top: 2rem;
    text-align: center;
    font-size: 0.85rem;
    color: #888;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .price-note a {
    color: var(--navy);
    font-weight: 600;
  }

  .order-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-delivery {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .delivery-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive */
  @media (max-width: 860px) {
    .menu-layout {
      flex-direction: column;
      gap: 1rem;
      position: relative;
    }
    .menu-sidebar {
      display: none;
    }
    .filter-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.75rem 1.5rem;
      border: 1px solid var(--gold);
      border-radius: 12px;
      background: var(--navy);
      color: var(--gold);
      font-family: 'Poppins', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      margin-bottom: 0.5rem;
    }
    .filter-toggle:active {
      transform: scale(0.98);
    }
    .filter-toggle svg {
      flex-shrink: 0;
    }
    .filter-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1000;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s ease, visibility 0.25s ease;
    }
    .filter-backdrop.active {
      opacity: 1;
      visibility: visible;
    }
    .filter-popup {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      max-height: 70vh;
      background: var(--white);
      border-radius: 20px 20px 0 0;
      z-index: 1001;
      padding: 1.25rem 1.5rem 2rem;
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
      display: flex;
      flex-direction: column;
      box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.15);
    }
    .filter-popup.active {
      transform: translateY(0);
    }
    .filter-popup-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid rgba(0,0,0,0.08);
    }
    .filter-popup-header h3 {
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--navy);
      margin: 0;
    }
    .filter-popup-close {
      background: none;
      border: none;
      padding: 0.35rem;
      cursor: pointer;
      color: #888;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s ease, color 0.2s ease;
    }
    .filter-popup-close:hover,
    .filter-popup-close:active {
      background: rgba(0,0,0,0.06);
      color: var(--navy);
    }
    .filter-popup .filter-nav {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .filter-popup .filter-nav::-webkit-scrollbar {
      display: none;
    }
    .filter-popup .filter-btn {
      width: 100%;
      padding: 0.75rem 1rem;
      border: none;
      border-radius: 12px;
      background: transparent;
      color: #555;
      font-family: 'Poppins', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: left;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .filter-popup .filter-btn:hover {
      background: var(--light-gray);
      color: var(--navy);
    }
    .filter-popup .filter-btn.active {
      background: var(--navy);
      color: var(--white);
      box-shadow: 0 4px 12px rgba(11, 31, 58, 0.2);
    }
    .item-image {
      width: 130px;
      min-height: 110px;
    }
    .image-placeholder {
      min-height: 110px;
    }
  }

  @media (min-width: 861px) {
    .filter-toggle {
      display: none;
    }
    .filter-backdrop {
      display: none;
    }
    .filter-popup {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .menu-hero { padding: 6rem 1rem 3rem; }
    .menu-page { padding: 2rem 0; }
    .menu-layout { padding: 0 1rem; }
    .item-image {
      width: 100px;
      min-height: 100px;
    }
    .image-placeholder {
      min-height: 100px;
    }
    .item-header { flex-direction: column; gap: 0.5rem; }
  }
</style>
