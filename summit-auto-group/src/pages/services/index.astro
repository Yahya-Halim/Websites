---
import PageLayout from '../../components/PageLayout.astro';
import { getCollection } from 'astro:content';
import { webPage, itemList } from '../../lib/schema';

const services = await getCollection('services');

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Services', path: '/services' },
];

const description =
  'Summit Auto Group services in Denver: full-service maintenance for all makes, free trade-in appraisals, and extended warranty & protection plans.';

const schemas = [
  webPage({ name: 'Our Services', path: '/services', description, type: 'CollectionPage' }),
  itemList(
    'Summit Auto Group Services',
    services.map((s) => ({ name: s.data.name, path: `/services/${s.data.slug}` })),
  ),
];
---

<PageLayout
  title="Auto Services in Denver — Maintenance, Trade-In, Warranty | Summit Auto Group"
  description={description}
  breadcrumbs={crumbs}
  eyebrow="Services"
  heroTitle="Services beyond the sale"
  heroSubtitle="Everything you need to buy with confidence and keep your vehicle running for years."
  schemas={schemas}
>
  <div class="grid">
    {services.map((s) => (
      <div class="card">
        <h3>{s.data.name}</h3>
        <p>{s.data.description}</p>
        <a class="card-link" href={`/services/${s.data.slug}`}>Learn more →</a>
      </div>
    ))}
  </div>

  <div class="band">
    <h2>One team, start to finish</h2>
    <p>Buy, finance, protect, and maintain — all under one roof on Federal Blvd. Our
      <a href="/locations/denver">Denver service center</a> welcomes every make and model.</p>
    <div class="btn-row">
      <a class="btn" href="/contact">Book service</a>
      <a class="btn ghost" href="/inventory">Shop inventory</a>
    </div>
  </div>
</PageLayout>
