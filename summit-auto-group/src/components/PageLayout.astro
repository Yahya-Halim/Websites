---
import Base from '@engine/layouts/Base.astro';
import { breadcrumbList, type Crumb } from '../lib/schema';

interface Props {
  title: string;
  description?: string;
  breadcrumbs?: Crumb[];
  eyebrow?: string;
  heroTitle?: string;
  heroSubtitle?: string;
  schemas?: unknown[];
}

const {
  title,
  description,
  breadcrumbs = [],
  eyebrow,
  heroTitle,
  heroSubtitle,
  schemas = [],
} = Astro.props;

const jsonLd: unknown[] = [
  ...(breadcrumbs.length > 1 ? [breadcrumbList(breadcrumbs)] : []),
  ...schemas,
];
---

<Base title={title} description={description}>
  {breadcrumbs.length > 0 && (
    <nav class="crumbs" aria-label="Breadcrumb">
      <ol>
        {breadcrumbs.map((c, i) => (
          <li>
            {c.path && i < breadcrumbs.length - 1 ? <a href={c.path}>{c.name}</a> : <span>{c.name}</span>}
          </li>
        ))}
      </ol>
    </nav>
  )}

  {heroTitle && (
    <header class="page-header">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{heroTitle}</h1>
      {heroSubtitle && <p>{heroSubtitle}</p>}
    </header>
  )}

  <slot />

  {jsonLd.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
</Base>

<style is:global>
  :root {
    --brand: #0b3d2e;
    --brand-2: #1b6b52;
    --gold: #f2a900;
    --ink: #12241d;
    --muted: #5a6b63;
    --line: #e3e8e5;
    --bg-soft: #f2f6f4;
  }
  body {
    --accent-color: #0b3d2e;
    color: var(--ink);
    background: #fff;
  }
  a { color: var(--brand-2); }

  .crumbs ol {
    list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem;
    padding: 0; margin: 1rem 0 0; font-size: 0.85rem; color: var(--muted);
  }
  .crumbs li:not(:last-child)::after { content: '/'; margin-left: 0.4rem; color: var(--line); }
  .crumbs a { color: var(--brand-2); text-decoration: none; }
  .crumbs a:hover { text-decoration: underline; }

  .page-header { padding: 1.25rem 0 1rem; border-bottom: 1px solid var(--line); margin-bottom: 1.75rem; }
  .page-header h1 { font-size: 2.1rem; line-height: 1.15; margin: 0.3rem 0 0.5rem; color: var(--brand); }
  .page-header p { color: var(--muted); font-size: 1.05rem; max-width: 48rem; margin: 0.35rem 0; }
  .eyebrow { text-transform: uppercase; letter-spacing: 0.09em; font-size: 0.72rem; font-weight: 700; color: var(--gold); margin: 0; }

  .prose { max-width: 46rem; line-height: 1.7; }
  .prose h2 { color: var(--brand); font-size: 1.4rem; margin: 2rem 0 0.6rem; }
  .prose h3 { color: var(--brand-2); font-size: 1.1rem; margin: 1.4rem 0 0.4rem; }
  .prose ul { padding-left: 1.15rem; }
  .prose li { margin: 0.3rem 0; }

  .grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); margin: 1.5rem 0; }
  .card { border: 1px solid var(--line); border-radius: 0.75rem; padding: 1.25rem; background: #fff; }
  .card h3 { margin: 0 0 0.4rem; color: var(--brand); font-size: 1.15rem; }
  .card p { margin: 0 0 0.6rem; color: var(--muted); }
  .card a.card-link { font-weight: 600; text-decoration: none; }

  .btn {
    display: inline-block; background: var(--brand); color: #fff; padding: 0.7rem 1.15rem;
    border-radius: 0.5rem; text-decoration: none; font-weight: 600;
  }
  .btn.gold { background: var(--gold); color: #1a1400; }
  .btn.ghost { background: transparent; color: var(--brand); border: 1px solid var(--brand); }
  .btn-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 1.5rem 0; }

  .band { background: var(--bg-soft); border: 1px solid var(--line); border-radius: 0.9rem; padding: 1.6rem; margin: 2rem 0; }
  .band h2 { margin-top: 0; color: var(--brand); }

  .faq { margin: 2.25rem 0; }
  .faq h2 { color: var(--brand); font-size: 1.4rem; }
  .faq-item { border: 1px solid var(--line); border-radius: 0.6rem; padding: 0.85rem 1.05rem; margin: 0.6rem 0; background: #fff; }
  .faq-item summary { cursor: pointer; font-weight: 600; color: var(--ink); }
  .faq-item p { margin: 0.6rem 0 0; color: var(--muted); line-height: 1.6; }

  .kv { display: grid; grid-template-columns: auto 1fr; gap: 0.35rem 1.1rem; margin: 1rem 0; }
  .kv dt { font-weight: 600; color: var(--brand-2); }
  .kv dd { margin: 0; color: var(--ink); }
</style>
