{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://summitautogroup.example/#website",
  "url": "https://summitautogroup.example",
  "name": "Summit Auto Group",
  "publisher": {
    "@id": "https://summitautogroup.example/#business"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://summitautogroup.example/?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}