---
import Base from '@engine/layouts/Base.astro';
import { getEntry } from 'astro:content';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

const title = business?.name ?? 'Welcome';
const description = business?.description ?? '';
const tagline = business?.tagline ?? '';
---

<Base title={title} description={description}>
  <section class="hero">
    <h1>{title}</h1>
    {tagline && <p class="tagline">{tagline}</p>}
    {description && <p class="description">{description}</p>}
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 0;
    text-align: center;
  }
  h1 {
    font-size: 2.5rem;
    margin: 0 0 1rem;
  }
  .tagline {
    font-size: 1.25rem;
    color: #6b6b6b;
    margin: 0 0 1.5rem;
  }
  .description {
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.6;
  }
</style>
