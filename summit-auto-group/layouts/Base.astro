---
import Header from '@engine/components/Header.astro';
import Footer from '@engine/components/Footer.astro';

interface Props {
  /** Per-page <title>. Defaults to the business name when omitted. */
  title?: string;
  /** Per-page meta description. */
  description?: string;
}

const { title, description } = Astro.props;

// Canonical URL is computed from the configured `site` (sourced from
// business.domain in astro.config.mjs) joined with the current pathname.
// Without this tag, marker checks that assert <link rel="canonical">
// fail and SEO/sitemap consistency is weakened.
const canonicalHref = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;

// JSON-LD generated by `factory wire` lives in src/content/_generated/.
// We inline both as <script type="application/ld+json"> in <head> so
// crawlers see the LocalBusiness + WebSite entities on every page.
//
// Important: Base.astro sits in node_modules at build time. Relative
// imports walking up from there land in node_modules, not the project.
// Use Vite's project-root-absolute path (/src/...) which resolves to
// the consumer project's src/ directory at build time.
import localbusinessLd from '/src/content/_generated/localbusiness.jsonld?raw';
import websiteLd from '/src/content/_generated/website.jsonld?raw';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ?? 'Untitled'}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalHref} />

    {/* JSON-LD injected from generated artifacts (amendment #5 outputs) */}
    <script type="application/ld+json" set:html={localbusinessLd} />
    <script type="application/ld+json" set:html={websiteLd} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
    color: #222;
    background: #fff;
    --accent-color: #f60;
  }
  main {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
</style>
