---
/**
 * FinancingBlock — financing/partner providers (cro-gates Task 4).
 *
 * Sourced from `site.financing.providers[]` (T1: `{name, url?}`). Renders each
 * provider's name, linked when a url is present. KG7: empty/absent providers →
 * renders NOTHING (no marker). When it renders, the root carries
 * `data-cro-block="financing-block"`.
 */
interface FinancingProvider {
  name: string;
  url?: string;
}

interface Props {
  /** The `site.financing.providers` array. */
  providers?: FinancingProvider[];
}

const { providers } = Astro.props;
const hasProviders = Array.isArray(providers) && providers.length > 0;
---

{hasProviders && (
  <section class="financing-block" data-cro-block="financing-block">
    <ul class="financing-list">
      {providers!.map((provider) => (
        <li class="financing-provider">
          {provider.url ? (
            <a href={provider.url} rel="noopener">{provider.name}</a>
          ) : (
            <span>{provider.name}</span>
          )}
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .financing-block {
    margin: 2rem 0;
  }
  .financing-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .financing-provider a {
    color: var(--accent-color, #f60);
    text-decoration: none;
    font-weight: 600;
  }
  .financing-provider span {
    font-weight: 600;
  }
</style>
