---
import Base from '../../layouts/Base.astro';
import guides from '../../data/guides.json';
import { telHref, telDisplay, orderUrl } from '../../lib/site';

export function getStaticPaths() {
  return (guides as any[]).map((g) => ({ params: { slug: g.slug }, props: { guide: g } }));
}
const { guide } = Astro.props as { guide: any };
const related = (guide.related ?? [])
  .map((s: string) => (guides as any[]).find((g) => g.slug === s))
  .filter(Boolean)
  .slice(0, 3);

const title = `${guide.title} | Captains Fish and Chicken, Cedar Rapids`;
const description = guide.excerpt;

const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: '/' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: '/guides/' },
    { '@type': 'ListItem', position: 3, name: guide.title, item: `/guides/${guide.slug}/` },
  ],
};
const articleLd = {
  '@context': 'https://schema.org', '@type': 'Article',
  headline: guide.title, description: guide.excerpt,
  author: { '@type': 'Organization', name: 'Captains Fish and Chicken' },
  publisher: { '@type': 'Organization', name: 'Captains Fish and Chicken' },
  ...(guide.updated ? { dateModified: guide.updated } : {}),
};
const faqLd = guide.faqs?.length ? { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: guide.faqs.map((f: any) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) } : null;
const jsonLd = [breadcrumb, articleLd, ...(faqLd ? [faqLd] : [])];
---
<Base title={title} description={description} jsonLd={jsonLd}>
  <section class="section section--navy-deep" style="padding-block:52px">
    <div class="wrap-narrow">
      <nav class="crumbs"><a href="/">Home</a> / <a href="/guides/">Guides</a> / {guide.category}</nav>
      <span class="eyebrow" style="margin-top:14px">{guide.category}</span>
      <h1 class="display h-xl" style="margin-top:10px">{guide.title}</h1>
      <p class="lead mt-s">{guide.excerpt}</p>
    </div>
  </section>
  <section class="section section--cream">
    <div class="wrap-narrow">
      {(guide.body ?? []).map((block: any) => (
        <div style="margin-bottom:30px">
          {block.h && <h2 class="display h-md" style="color:var(--navy-800);font-size:1.5rem;margin-bottom:10px">{block.h}</h2>}
          <div class="stack" style="--s:16px">{(block.p ?? []).map((p: string) => <p class="lead" style="font-size:1.06rem">{p}</p>)}</div>
        </div>
      ))}
      <div class="hero__cta mt-l"><a class="btn btn--lg" href={telHref}>Call {telDisplay}</a><a class="btn btn--navy btn--lg" href={orderUrl} target="_blank" rel="noopener">Order Online</a></div>

      {guide.faqs?.length > 0 && (
        <div class="mt-l">
          <h2 class="display h-md" style="color:var(--navy-800)">FAQ</h2>
          <div class="faq mt-s">{guide.faqs.map((f: any) => <details><summary>{f.q}</summary><p>{f.a}</p></details>)}</div>
        </div>
      )}
    </div>
  </section>
  {related.length > 0 && (
    <section class="section section--paper">
      <div class="wrap">
        <h2 class="display h-md" style="color:var(--navy-800)">Keep reading</h2>
        <div class="grid grid--3 mt-m">
          {related.map((r: any) => <a class="card card--link" href={`/guides/${r.slug}/`}><span class="tag">{r.category}</span><h3>{r.title}</h3><p class="card__desc">{r.excerpt}</p></a>)}
        </div>
      </div>
    </section>
  )}
</Base>
