---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'node:fs';
import { business, telHref, orderUrl } from '../lib/site';

export interface Props {
  title: string;
  description: string;
  jsonLd?: Record<string, unknown>[];
  image?: string;
  noindex?: boolean;
}

const { title, description, jsonLd = [], image = '/images/logo-lg.png', noindex = false } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://captainsfishandchicken.com').href;

// Site-wide JSON-LD emitted by `factory wire` (Restaurant + WebSite entities).
let localBusinessLd = '';
let webSiteLd = '';
try { localBusinessLd = readFileSync(new URL('../content/_generated/localbusiness.jsonld', import.meta.url), 'utf8'); } catch {}
try { webSiteLd = readFileSync(new URL('../content/_generated/website.jsonld', import.meta.url), 'utf8'); } catch {}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="theme-color" content="#072d44" />
    <link rel="icon" type="image/png" href="/images/logo-nav.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Open Graph -->
    <meta property="og:type" content="restaurant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site ?? 'https://captainsfishandchicken.com').href} />
    <meta property="og:site_name" content="Captains Fish and Chicken" />
    <meta name="twitter:card" content="summary_large_image" />
    {localBusinessLd && <script type="application/ld+json" set:html={localBusinessLd} />}
    {webSiteLd && <script type="application/ld+json" set:html={webSiteLd} />}
    {jsonLd.map((block) => <script type="application/ld+json" set:html={JSON.stringify(block)} />)}
  </head>
  <body>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <nav class="mobile-bar" aria-label="Quick actions">
      <a class="m-call" href={telHref}>Call to Order</a>
      <a class="m-order" href={orderUrl} target="_blank" rel="noopener">Order Online</a>
    </nav>
  </body>
</html>
