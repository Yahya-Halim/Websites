---
import Base from '../layouts/Base.astro';
// Scaffolded INTO the consumer project by `factory init` (unlike the shared
// home, which is engine-injected), so the generators resolve via the PACKAGE
// SUBPATH — the proven content.config.ts.tpl import channel — NOT the
// @engine/generators alias (that alias only exists for engine-injected files).
import {
  renderWebPageJsonLd,
  renderBreadcrumbJsonLd,
} from '@localevolve/local-biz-factory-engine/generators';
import { getEntry } from 'astro:content';
// CRO blocks (T4) composed into contact. Scaffolded page → the
// @engine/components alias, same channel Header/Footer already use here.
import LeadForm from '@engine/components/LeadForm.astro';
import OfferCallout from '@engine/components/OfferCallout.astro';
import CtaBanner from '@engine/components/CtaBanner.astro';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

// site.json drives the CRO blocks on contact (lead-form endpoint + conditional
// offers). LeadForm renders ONLY when site.leadForm (incl. its external
// endpoint) is present — a site without an endpoint ships contact as
// phone + address + hours + directions (KG7, omit-never-fabricate).
const siteEntry = await getEntry('site', 'site');
const site = siteEntry?.data;
const leadForm = site?.leadForm;

// NAP + page metadata sourced from business data only (no literals).
const name = business?.name ?? 'Contact';
const phone = business?.phone ?? '';
const email = business?.email ?? '';
const address = business?.address;
const hoursText = business?.hours?.displayText ?? '';
const mapsUrl = business?.mapsUrl;
const directionsUrl = business?.directionsUrl;
const description = 'Find Captains Fish and Chicken: 1616 1st Ave NE, Cedar Rapids, IA. Call (319) 221-1040 to order, get directions, and see hours. Takeout, delivery & catering.';

const title = `Contact ${name}`;

const siteRoot = Astro.site ? Astro.site.href : '/';
const contactUrl = Astro.site ? new URL('/contact/', Astro.site).href : '/contact/';
const websiteUrl = business?.domain ?? siteRoot;

const webPageLd = renderWebPageJsonLd({
  name: title,
  url: contactUrl,
  description,
  websiteName: name,
  websiteUrl,
  schemaType: 'ContactPage',
  speakableSelectors: ['.hero-copy h1', '.hero-subheading'],
});

// Breadcrumb Home → Contact (url-less final crumb).
const breadcrumbLd = renderBreadcrumbJsonLd({
  trail: [
    { name: 'Home', url: siteRoot },
    { name: 'Contact' },
  ],
});
---

<Base title={title} description={description} jsonLd={[webPageLd, breadcrumbLd]}>
  <section class="contact">
    <span class="eyebrow">FIND US</span>
    <h1>Contact {name}</h1>

    <dl class="nap">
      {phone && (
        <>
          <dt>Phone</dt>
          <dd><a href={`tel:${phone}`}>{phone}</a></dd>
        </>
      )}
      {email && (
        <>
          <dt>Email</dt>
          <dd><a href={`mailto:${email}`}>{email}</a></dd>
        </>
      )}
      {address && (
        <>
          <dt>Address</dt>
          <dd>
            <address>
              {address.street}<br />
              {address.city}, {address.state} {address.zip}
            </address>
          </dd>
        </>
      )}
      {hoursText && (
        <>
          <dt>Hours</dt>
          <dd>{hoursText}</dd>
        </>
      )}
    </dl>

    {phone && (
      <p class="contact-cta">
        <a class="cta" href={`tel:${phone}`}>Call {phone}</a>
      </p>
    )}

    {(mapsUrl || directionsUrl) && (
      <p class="map-links">
        {mapsUrl && <a href={mapsUrl}>View on map</a>}
        {directionsUrl && <a href={directionsUrl}>Get directions</a>}
      </p>
    )}

    {/* Lead-capture form → external provider endpoint (site.leadForm). */}
    <LeadForm leadForm={leadForm} />

    {/* Conditional promo block (KG7 — only when data present). */}
    <OfferCallout offers={site?.offers} />

    {/* Mid-page full-width CTA band (site.ctaBanner) + call CTA — matches home. */}
    <CtaBanner
      ctaBanner={site?.ctaBanner}
      ctaPrimary={site?.ctaPrimary}
      ctaSecondary={site?.ctaSecondary}
    />
  </section>
</Base>

<style>
  .contact {
    padding: 2rem 0;
  }
  /* NAP card — the page's information core gets the card language. */
  .nap {
    background: var(--white, #fff);
    border: 1px solid var(--steel-200, #d5dfe9);
    border-radius: var(--radius-md, 0.75rem);
    box-shadow: var(--shadow-sm);
    padding: 1.5rem;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.85rem 1.75rem;
    max-width: 40rem;
  }
  .nap dt {
    font-weight: 700;
    color: var(--navy-700, #123253);
    margin: 0;
  }
  .nap dd {
    margin: 0;
    color: var(--ink-soft, #3c4f66);
  }
  .nap dd address {
    font-style: normal;
    line-height: 1.6;
  }
  /* Oversized tap-to-call number — the page's whole job. */
  .nap dd a[href^='tel:'] {
    font-size: clamp(1.15rem, 3vw, 1.5rem);
    font-weight: 800;
    color: var(--navy-700, #123253);
    text-decoration: none;
  }
  .nap dd a[href^='tel:']:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .contact-cta {
    margin: 1.75rem 0 0;
  }
  .contact-cta .cta {
    font-size: 1.05rem;
    padding: 0.75rem 1.6rem;
    text-decoration: none;
  }
  .map-links {
    margin: 1.5rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  /* Map/directions ride the secondary-pill language. */
  .map-links a {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    background: var(--white, #fff);
    color: var(--navy-700, #123253);
    border: 1.5px solid var(--navy-600, #1a4470);
    border-radius: 999px;
    padding: 0.4rem 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .map-links a:hover {
    background: var(--steel-100, #e8eef4);
  }
  @media (max-width: 30rem) {
    .nap {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
    .nap dd {
      margin-bottom: 0.85rem;
    }
  }
</style>
