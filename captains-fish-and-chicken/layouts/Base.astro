---
import { getEntry } from 'astro:content';
import Header from '@engine/components/Header.astro';
import Footer from '@engine/components/Footer.astro';
import Analytics from '@engine/components/Analytics.astro';
import StickyCallBar from '@engine/components/StickyCallBar.astro';

interface Props {
  /** Per-page <title>. Defaults to the business name when omitted. */
  title?: string;
  /** Per-page meta description. */
  description?: string;
  /**
   * Optional robots directive. ABSENT → NO robots meta is emitted (content pages
   * stay indexable — today's behavior). PRESENT → a `<meta name="robots">` is
   * rendered in <head>, guarded exactly like `description`. This is the ONLY path
   * a funnel route (T5's /thank-you, /request-estimate, /call-or-text-pop) gets
   * `robots="noindex"` into <head> (R3-F1).
   */
  robots?: string;
  /**
   * Per-page JSON-LD blocks — an array of already-rendered ld+json strings (or
   * nulls). Base filters out null/undefined entries and renders one
   * <script type="application/ld+json"> per surviving string, AFTER the
   * localbusiness + website scripts. Optional: absent/empty → head unchanged.
   * Strings arrive pre-rendered so the layout stays dumb and generators stay
   * testable — Base calls no engine code here.
   */
  jsonLd?: (string | null | undefined)[];
}

const { title, description, robots, jsonLd } = Astro.props;

// Site-wide dual-CTA channel for the Base-owned StickyCallBar singleton (F5).
// The sticky bar is mounted EXACTLY ONCE here for every page; it is never
// composed into an individual page. KG7: StickyCallBar renders nothing when
// neither CTA is present, so absent CTAs emit no empty bar.
const siteEntry = await getEntry('site', 'site');
const site = siteEntry?.data;
const stickyCtaPrimary = site?.ctaPrimary;
const stickyCtaSecondary = site?.ctaSecondary;

// Drop null/undefined entries so a page passing e.g. [serviceBlock, null,
// breadcrumbBlock] emits nothing for the null (the omission contract). Order of
// scripts follows array order.
const jsonLdBlocks = (jsonLd ?? []).filter(Boolean) as string[];

// Canonical URL is computed from the configured `site` (sourced from
// business.domain in astro.config.mjs) joined with the current pathname.
// Without this tag, marker checks that assert <link rel="canonical">
// fail and SEO/sitemap consistency is weakened.
const canonicalHref = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;

// JSON-LD generated by `factory wire` lives in src/content/_generated/.
// We inline both as <script type="application/ld+json"> in <head> so
// crawlers see the LocalBusiness + WebSite entities on every page.
//
// Important: Base.astro sits in node_modules at build time. Relative
// imports walking up from there land in node_modules, not the project.
// Use Vite's project-root-absolute path (/src/...) which resolves to
// the consumer project's src/ directory at build time.
import localbusinessLd from '/src/content/_generated/localbusiness.jsonld?raw';
import websiteLd from '/src/content/_generated/website.jsonld?raw';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ?? 'Untitled'}</title>
    {description && <meta name="description" content={description} />}
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalHref} />

    {/* GA4 (+ optional Ads) analytics head component (T5). Base never passes
        conversionPage — only the /thank-you route fires the generate_lead
        conversion (R6-F3). Renders nothing when analytics.gaId is absent. */}
    <Analytics />

    {/* JSON-LD injected from generated artifacts (amendment #5 outputs) */}
    <script type="application/ld+json" set:html={localbusinessLd} />
    <script type="application/ld+json" set:html={websiteLd} />

    {/* Per-page JSON-LD blocks (WebPage, Service, Breadcrumb, ...), rendered
        pre-null-filtered in array order, AFTER the site-wide scripts above. */}
    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={block} />
    ))}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    {/* Site-wide sticky call/text bar — mounted EXACTLY ONCE, here, for every
        page (F5). Never composed into an individual page; every page inherits
        this single bar through Base. */}
    <StickyCallBar ctaPrimary={stickyCtaPrimary} ctaSecondary={stickyCtaSecondary} />
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
    color: #222;
    background: #fff;
    --accent-color: #f60;
  }
  main {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
</style>
