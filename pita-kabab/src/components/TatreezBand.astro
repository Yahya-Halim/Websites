---
// Palestinian tatreez motif — "najmet Beit Lahm" (Bethlehem eight-point star)
// with a saw-tooth running stitch, authored on a counted 4px grid as inline SVG.
// Decorative only (aria-hidden); colour comes from CSS `currentColor` so the same
// mark reads olive on light grounds (dividers) and gold on forest (hem/footer).
// Amendment 2 (Tatreez Modern — Palestinian carte).
interface Props {
  /** Extra class for placement/colour (default: tatreez-divider). */
  class?: string;
}
const { class: className = 'tatreez-divider' } = Astro.props;
