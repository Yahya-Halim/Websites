---
import Base from '../../layouts/Base.astro';
// Package-subpath import channel (scaffolded page — see contact.astro).
import {
  renderWebPageJsonLd,
  renderBreadcrumbJsonLd,
  renderFaqJsonLd,
} from '@localevolve/local-biz-factory-engine/generators';
import { getEntry, getCollection } from 'astro:content';
// CRO blocks (T4) composed into the menu-category kind.
import Hero from '@engine/components/Hero.astro';
import TrustBar from '@engine/components/TrustBar.astro';
import OfferCallout from '@engine/components/OfferCallout.astro';
import CtaBanner from '@engine/components/CtaBanner.astro';

// One static page per menu-collection section, keyed by the entry's own
// `slug` field. Empty collection → no paths → route generates nothing (the
// scaffold default ships an empty menu.json and still builds).
export async function getStaticPaths() {
  const sections = await getCollection('menu');
  return sections.map((section) => ({
    params: { slug: section.data.slug },
    props: { section },
  }));
}

const { section } = Astro.props;
const s = section.data;

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

// site.json drives the CRO blocks (hero dual-CTA, trust bar, conditional promos).
const siteEntry = await getEntry('site', 'site');
const site = siteEntry?.data;
const legacyTelCta = site?.cta?.href?.startsWith('tel:') ? site.cta : undefined;
const routeCtaPrimary = site?.ctaPrimary ?? legacyTelCta;
const routeCtaSecondary = site?.ctaSecondary;

const name = s.name;
const description = s.description ?? '';
// seo is optional on menu sections; fall back to data-derived metadata.
const businessName = business?.name ?? '';
const title = s.seo?.title ?? `${name} — ${businessName}`;
const metaDescription = s.seo?.description ?? description;
const faqs = s.faqs ?? [];
const crossLinks = s.crossLinks ?? [];

const siteRoot = Astro.site ? Astro.site.href : '/';
const pageUrl = Astro.site
  ? new URL(`/menu/${s.slug}/`, Astro.site).href
  : `/menu/${s.slug}/`;
const websiteUrl = business?.domain ?? siteRoot;
const menuUrl = Astro.site ? new URL('/menu/', Astro.site).href : '/menu/';

const webPageLd = renderWebPageJsonLd({
  name: title,
  url: pageUrl,
  description: metaDescription,
  websiteName: businessName,
  websiteUrl,
});

// Home → Menu → {name}. Menu crumb carries the real /menu/ hub url.
const breadcrumbLd = renderBreadcrumbJsonLd({
  trail: [
    { name: 'Home', url: siteRoot },
    { name: 'Menu', url: menuUrl },
    { name },
  ],
});

const faqLd = renderFaqJsonLd({ faqs });

// Prices render ONLY when the item carries owner-authoritative price data
// (prices is optional — omit-never-fabricate; no placeholder amounts).
const priceLine = (prices) =>
  (prices ?? []).map((p) => (prices.length > 1 ? `${p.label} $${p.price.toFixed(2)}` : `$${p.price.toFixed(2)}`)).join(' · ');

// Per-item representational photo (public/images/items/<slug>.webp). Slug is
// derived from the item name and matches the generated filenames.
const itemSlug = (str) => str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

// Draft Naskh dish names — ship HIDDEN until owner Ray Aqel verifies the Arabic
// (Phase 3 amendment-2 guard gate). English spellings stay owner-canonical.
const enableArabic = false;
const arabicName = {
  'Hummus': 'حُمُّص',
  'Foul': 'فول',
  'Falafel sandwich': 'فلافل',
  'Chicken shawarma sandwich': 'شاورما',
};
---

<Base title={title} description={metaDescription} jsonLd={[webPageLd, breadcrumbLd, faqLd]}>
  <article class="menu-section">
    {/* Hero owns the page's single <h1> + hero-surface dual CTA (R3-F4).
        Wrapper carries the category food photo as a hero background (green
        overlay preserves white-text contrast). */}
    <div class="cat-hero" style={`--cat-img:url('/images/${s.slug}.webp')`}>
      <Hero
        heading={name}
        subheading={description}
        ctaPrimary={routeCtaPrimary}
        ctaSecondary={routeCtaSecondary}
      />
    </div>

    <section class="items" aria-labelledby="items-heading">
      <h2 id="items-heading">From the counter</h2>
      <ul>
        {s.items.map((item) => (
          <li class="menu-item">
            <img
              class="item-thumb"
              src={`/images/items/${itemSlug(item.name)}.webp`}
              alt={item.name}
              width="500"
              height="500"
              loading="lazy"
              decoding="async"
              onerror="this.style.display='none'"
            />
            <div class="item-body">
              <span class="item-name">{item.name}</span>
              {enableArabic && arabicName[item.name] && (
                <span class="item-name-ar" dir="rtl" lang="ar">{arabicName[item.name]}</span>
              )}
              {item.spicy && <span class="item-flag" aria-label="spicy">🌶</span>}
              {item.dietary && item.dietary.length > 0 && (
                <span class="item-dietary">{item.dietary.join(', ')}</span>
              )}
              {item.description && <p class="item-description">{item.description}</p>}
              {item.prices && item.prices.length > 0 && (
                <span class="item-prices">{priceLine(item.prices)}</span>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>

    {/* Trust-signal grid (site.trustBar.items ≥6 when present). */}
    <TrustBar items={site?.trustBar?.items} />

    {/* Conditional promo block (KG7 — only when data present). */}
    <OfferCallout offers={site?.offers} />

    {/* Mid-page CTA band + dual CTA (site.ctaBanner). */}
    <CtaBanner
      ctaBanner={site?.ctaBanner}
      ctaPrimary={routeCtaPrimary}
      ctaSecondary={routeCtaSecondary}
    />

    {faqs.length > 0 && (
      <section class="faqs" aria-labelledby="faqs-heading">
        <h2 id="faqs-heading">Frequently asked questions</h2>
        <dl>
          {faqs.map((faq) => (
            <>
              <dt>{faq.question}</dt>
              <dd>{faq.answer}</dd>
            </>
          ))}
        </dl>
      </section>
    )}

    {crossLinks.length > 0 && (
      <nav class="related" aria-labelledby="related-heading">
        <h2 id="related-heading">Related</h2>
        <ul>
          {crossLinks.map((link) => (
            <li><a href={link.slug}>{link.anchor}</a></li>
          ))}
        </ul>
      </nav>
    )}
  </article>
</Base>

<style>
  .menu-section {
    padding: 2rem 0;
  }
  .items {
    margin-top: 2rem;
  }
  .items ul {
    list-style: none;
    padding: 0;
  }
  .items li {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border, #dce6d2);
  }
  .menu-item {
    display: flex;
    gap: 1.1rem;
    align-items: center;
  }
  .item-thumb {
    flex: 0 0 auto;
    width: 92px;
    height: 92px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--color-border, #dce6d2);
  }
  .item-body {
    flex: 1 1 auto;
    min-width: 0;
  }
  .item-name {
    font-family: var(--font-display, Georgia, serif);
    font-weight: 600;
    font-size: 1.28rem;
    color: var(--color-foreground, #1c2b21);
  }
  .item-name-ar {
    font-family: var(--font-arabic, serif);
    font-weight: 500;
    color: var(--color-primary, #1b6e3e);
    margin-inline-start: 0.5rem;
  }
  .item-flag {
    margin-left: 0.35rem;
  }
  .item-dietary {
    margin-left: 0.5rem;
    font-size: 0.85rem;
    color: #666;
  }
  .item-description {
    margin: 0.3rem 0 0;
    font-family: var(--font-display, Georgia, serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-muted-foreground, #4c5a4e);
    line-height: 1.5;
  }
  .item-prices {
    display: block;
    margin-top: 0.3rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    color: var(--color-foreground, #1c2b21);
  }
  .faqs {
    margin-top: 2.5rem;
  }
  .faqs dt {
    font-weight: 600;
    margin-top: 1rem;
  }
  .faqs dd {
    margin: 0.25rem 0 0;
    line-height: 1.5;
  }
  .related {
    margin-top: 2rem;
  }
</style>
