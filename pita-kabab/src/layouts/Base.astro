---
// Project shadow of the engine Base layout (_OVERRIDES.md channel).
// Contract-identical head/body composition (title/description/robots/jsonLd,
// canonical, Analytics, generated LocalBusiness + WebSite JSON-LD, Header /
// Footer / site-wide StickyCallBar singleton) — plus the sealed Phase 3 design
// system: Fredoka + Nunito, warm-cream canvas, pomegranate CTA tokens
// (src/styles/tokens.css mirrors the workbench design-tokens.json).
import { getEntry } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@engine/components/Analytics.astro';
import StickyCallBar from '@engine/components/StickyCallBar.astro';
import '../styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
  robots?: string;
  jsonLd?: (string | null | undefined)[];
}

const { title, description, robots, jsonLd } = Astro.props;

// Site-wide dual-CTA channel for the Base-owned StickyCallBar singleton.
// Mounted EXACTLY ONCE here for every page (never composed into a page).
// KG7: StickyCallBar renders nothing when neither CTA is present.
const siteEntry = await getEntry('site', 'site');
const site = siteEntry?.data;
const legacyTelCta = site?.cta?.href?.startsWith('tel:') ? site.cta : undefined;
const stickyCtaPrimary = site?.ctaPrimary ?? legacyTelCta;
const stickyCtaSecondary = site?.ctaSecondary;
const hasStickyCallBar = Boolean(stickyCtaPrimary || stickyCtaSecondary);

const jsonLdBlocks = (jsonLd ?? []).filter(Boolean) as string[];

const canonicalHref = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;

// Generated by `factory wire` (LocalBusiness + WebSite entities on every page).
import localbusinessLd from '/src/content/_generated/localbusiness.jsonld?raw';
import websiteLd from '/src/content/_generated/website.jsonld?raw';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ?? 'Untitled'}</title>
    {description && <meta name="description" content={description} />}
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalHref} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="theme-color" content="#1B6E3E" />

    {/* Amendment 2: Fraunces (display serif) + IBM Plex Sans (body) + IBM Plex
        Mono (tracked eyebrows) + IBM Plex Sans Arabic (draft/gated). */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..600&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&family=IBM+Plex+Sans+Arabic:wght@400;500;600&display=swap"
    />

    <Analytics />

    <script type="application/ld+json" set:html={localbusinessLd} />
    <script type="application/ld+json" set:html={websiteLd} />
    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={block} />
    ))}
  </head>
  <body class:list={[hasStickyCallBar && 'has-sticky-call-bar']}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    {/* Site-wide sticky call bar — the layout singleton (single-CTA variant;
        the sms: half stays owner-gated and absent from site.json). */}
    <StickyCallBar ctaPrimary={stickyCtaPrimary} ctaSecondary={stickyCtaSecondary} />
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    --sticky-call-bar-reserved-space: calc(4.75rem + env(safe-area-inset-bottom, 0px));
  }
  /* Amendment 1 density: tighter container, green-tinted canvas set in tokens.css. */
  main {
    max-width: 70rem;
    margin: 0 auto;
    padding: 1.25rem 1.25rem 2.5rem;
  }
  @media (min-width: 48rem) {
    main {
      padding: 1.5rem 1.5rem 3rem;
    }
  }
  @media (max-width: 48rem) {
    body.has-sticky-call-bar {
      padding-bottom: var(--sticky-call-bar-reserved-space);
    }
  }
</style>
