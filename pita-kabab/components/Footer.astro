---
import { getEntry } from 'astro:content';
import CtaBar from '@engine/components/CtaBar.astro';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
const siteEntry = await getEntry('site', 'site');
const site = siteEntry?.data;

// NAP (name / address / phone) block, sourced from business data only.
const businessName = business?.name;
const phone = business?.phone;
const address = business?.address;
const serviceArea = business?.serviceArea;
const hoursText = business?.hours?.displayText;
const legacyTelCta = site?.cta?.href?.startsWith('tel:') ? site.cta : undefined;
const footerCtaPrimary = site?.ctaPrimary ?? legacyTelCta;
const footerCtaSecondary = site?.ctaSecondary;
---

<footer class="site-footer">
  {(businessName || phone || address || serviceArea || hoursText) && (
    <div class="footer-nap">
      {businessName && <p class="nap-name">{businessName}</p>}
      {phone && (
        <p class="nap-phone">
          <a href={`tel:${phone}`}>{phone}</a>
        </p>
      )}
      {address && (
        <address class="nap-address">
          {address.street}<br />
          {address.city}, {address.state} {address.zip}
        </address>
      )}
      {!address && serviceArea && (
        <p class="nap-service-area">
          {serviceArea.description
            ? serviceArea.description
            : serviceArea.areas.map((a) => a.name).join(', ')}
        </p>
      )}
      {hoursText && <p class="nap-hours">{hoursText}</p>}
    </div>
  )}

  {(footerCtaPrimary || footerCtaSecondary) && (
    <CtaBar surface="footer" ctaPrimary={footerCtaPrimary} ctaSecondary={footerCtaSecondary} />
  )}

  <p class="copyright">
    {site?.footer?.copyrightText ?? `© ${business?.copyrightYears ?? new Date().getFullYear()} ${business?.name ?? ''}`}
  </p>
  {site?.footer?.links && site.footer.links.length > 0 && (
    <nav class="footer-nav">
      <ul>
        {site.footer.links.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  )}
</footer>

<style>
  .site-footer {
    padding: 2rem 1.5rem;
    border-top: 1px solid #e5e5e5;
    text-align: center;
    color: #6b6b6b;
  }
  .footer-nap {
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }
  .nap-name {
    font-weight: 700;
    color: #222;
    margin: 0 0 0.25rem;
  }
  .nap-phone {
    margin: 0 0 0.25rem;
  }
  .nap-phone a {
    color: inherit;
    text-decoration: none;
    font-weight: 600;
  }
  .nap-address {
    font-style: normal;
    margin: 0 0 0.25rem;
  }
  .nap-service-area,
  .nap-hours {
    margin: 0 0 0.25rem;
  }
  .site-footer :global(.cta-bar) {
    justify-content: center;
    margin: 0 0 1.25rem;
  }
  .copyright {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
  }
  .footer-nav ul {
    list-style: none;
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin: 0;
    padding: 0;
  }
  .footer-nav a {
    color: inherit;
    text-decoration: none;
  }
</style>
