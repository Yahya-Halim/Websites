---
/**
 * StickyCallBar — a fixed mobile-only call/text bar (cro-gates Task 4).
 *
 * A `position:fixed` bar pinned to the bottom of the viewport, shown ONLY on
 * mobile (a CSS media query hides it on desktop) with call + text actions. It
 * ships ZERO client JS — visibility is pure CSS. Base-owned/site-wide via Task
 * 14; the Header does NOT mount it.
 *
 * KG7: with neither CTA present → renders NOTHING (no marker). When it renders,
 * the root carries `data-cro-block="sticky-call-bar"`.
 */
interface CtaLink {
  text: string;
  href: string;
}

interface Props {
  ctaPrimary?: CtaLink;
  ctaSecondary?: CtaLink;
}

const { ctaPrimary, ctaSecondary } = Astro.props;
const hasCta = Boolean(ctaPrimary || ctaSecondary);
---

{hasCta && (
  <div class="sticky-call-bar" data-cro-block="sticky-call-bar">
    {ctaPrimary && (
      <a class="sticky-action sticky-call" href={ctaPrimary.href}>{ctaPrimary.text}</a>
    )}
    {ctaSecondary && (
      <a class="sticky-action sticky-text" href={ctaSecondary.href}>{ctaSecondary.text}</a>
    )}
  </div>
)}

<style>
  .sticky-call-bar {
    /* Hidden on desktop; the mobile media query below reveals it. */
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    gap: 0.5rem;
    padding: 0.5rem 0.5rem calc(0.5rem + env(safe-area-inset-bottom, 0px));
    background: #fff;
    border-top: 1px solid #e5e5e5;
    box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.08);
  }
  .sticky-action {
    flex: 1 1 0;
    min-width: 0;
    text-align: center;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    text-decoration: none;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sticky-call {
    background: var(--accent-color, #f60);
    color: #fff;
  }
  .sticky-text {
    background: transparent;
    color: var(--accent-color, #f60);
    border: 1px solid var(--accent-color, #f60);
  }
  @media (max-width: 48rem) {
    .sticky-call-bar {
      display: flex;
    }
  }
</style>
