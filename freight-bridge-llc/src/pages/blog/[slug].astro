---
import Base from '@engine/layouts/Base.astro';
import { getEntry, getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
const base = business?.domain ?? '';
const postUrl = `${base}/blog/${post.id}`;

const dateLabel = new Date(`${post.data.pubDate}T00:00:00`).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const allPosts = await getCollection('blog');
const related = allPosts.filter((p) => p.id !== post.id).slice(0, 2);

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.pubDate,
  dateModified: post.data.pubDate,
  author: { '@type': 'Organization', name: business?.name, url: `${base}/about` },
  publisher: {
    '@type': 'Organization',
    name: business?.name,
    logo: { '@type': 'ImageObject', url: `${base}/${business?.brand?.logoFilename}` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${base}/` },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: `${base}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
  ],
};
---

<Base title={`${post.data.title} | ${business?.name}`} description={post.data.excerpt}>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <article class="post">
    <header class="post-head" data-reveal>
      <a href="/blog" class="post-back">← All guides</a>
      <h1>{post.data.title}</h1>
      <p class="post-meta">
        {post.data.author && <span>By {post.data.author}</span>}
        <span>{dateLabel}</span>
        {post.data.readTime && <span>{post.data.readTime}</span>}
      </p>
      <p class="post-excerpt">{post.data.excerpt}</p>
    </header>

    <div class="post-body" data-reveal>
      <Content />
    </div>

    {/* Author / expertise box — E-E-A-T */}
    <aside class="author-box" data-reveal>
      <div class="author-avatar">FB</div>
      <div>
        <strong>{business?.name}</strong>
        <p>
          Licensed moving and freight company based in {business?.address.city}, {business?.address.stateFullName},
          founded in 2020 by owner {business?.owner}. {business?.movesCompleted} moves completed, USDOT
          {business?.dotNumber}, serving {business?.statesServed}.
          <a href="/about">More about our team →</a>
        </p>
      </div>
    </aside>
  </article>

  {related.length > 0 && (
    <section class="section">
      <div class="section-head" data-reveal>
        <span class="kicker">Keep reading</span>
        <h2>More moving & freight guides</h2>
      </div>
      <div class="grid-2">
        {related.map((p) => (
          <a href={`/blog/${p.id}`} class="card" data-reveal>
            <h3>{p.data.title}</h3>
            <p>{p.data.excerpt}</p>
            <span class="card-link">Read guide <span class="arrow">→</span></span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="cta">
    <div class="cta-bg" aria-hidden="true"></div>
    <h2>Planning a move or shipment?</h2>
    <p>Talk to {business?.owner} directly for a straight, same-day quote.</p>
    <div class="hero-cta">
      <a href="/contact" class="btn btn-primary">Get a Quote</a>
      <a href={`tel:${business?.phone}`} class="btn btn-ghost-light">Call {business?.phone}</a>
    </div>
  </section>
</Base>

<style>
  .post { max-width: 46rem; margin: 0 auto; }
  .post-head { margin: 1.5rem 0 2rem; }
  .post-back { font-size: 0.9rem; font-weight: 600; text-decoration: none; color: var(--blue); }
  .post-head h1 { font-size: clamp(1.9rem, 4vw, 2.8rem); color: var(--ink); margin: 1rem 0 0.75rem; }
  .post-meta { display: flex; flex-wrap: wrap; gap: 1rem; color: var(--muted); font-size: 0.88rem; margin: 0 0 1rem; }
  .post-meta span { position: relative; }
  .post-excerpt { font-size: 1.15rem; line-height: 1.7; color: var(--muted); margin: 0; }

  .post-body { color: var(--ink); line-height: 1.8; font-size: 1.05rem; }
  .post-body :global(h2) { font-family: var(--font-head); font-size: 1.6rem; color: var(--navy); margin: 2.5rem 0 1rem; }
  .post-body :global(h3) { font-family: var(--font-head); font-size: 1.25rem; color: var(--navy); margin: 1.75rem 0 0.75rem; }
  .post-body :global(p) { margin: 0 0 1.25rem; }
  .post-body :global(ul), .post-body :global(ol) { margin: 0 0 1.25rem; padding-left: 1.4rem; }
  .post-body :global(li) { margin: 0 0 0.5rem; }
  .post-body :global(strong) { color: var(--ink); }
  .post-body :global(a) { color: var(--blue); }
  .post-body :global(blockquote) {
    border-left: 4px solid var(--blue); margin: 1.5rem 0; padding: 0.5rem 1.25rem;
    background: var(--surface); border-radius: 0 var(--r) var(--r) 0; color: var(--muted);
  }
  .post-body :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2rem 0; }

  .author-box {
    display: flex; gap: 1rem; align-items: flex-start; max-width: 46rem; margin: 3rem auto 0;
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 1.5rem;
  }
  .author-avatar {
    flex-shrink: 0; width: 52px; height: 52px; border-radius: 14px; background: var(--grad-brand);
    color: #fff; font-family: var(--font-head); font-weight: 700; display: inline-flex;
    align-items: center; justify-content: center;
  }
  .author-box strong { color: var(--navy); font-size: 1.05rem; }
  .author-box p { margin: 0.4rem 0 0; color: var(--muted); font-size: 0.92rem; line-height: 1.6; }
  .author-box a { color: var(--blue); font-weight: 600; white-space: nowrap; }
</style>
