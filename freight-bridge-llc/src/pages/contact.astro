---
import Base from '@engine/layouts/Base.astro';
import { getEntry } from 'astro:content';
import reviews from '/src/data/content/reviews.json';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

const contactReviews = reviews.slice(0, 3);
const avgRating = (reviews.reduce((a, r) => a + r.rating, 0) / reviews.length).toFixed(1);

// Web3Forms — paste your free access key here (get one at https://web3forms.com,
// just enter your email; it's a public key, safe to ship in the page).
const WEB3FORMS_ACCESS_KEY = '40e4a498-e4e6-4f28-86fb-0978d682d1e7';
---

<Base title={`Contact Us | ${business?.name}`} description={`Get in touch with ${business?.name}. Request a quote for moving, nationwide freight hauling, or data center hauling.`}>
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">Contact us</span>
        <h1>Let's get you <span class="grad">a straight quote.</span></h1>
        <p class="lead">Need a move or a load hauled? Tell us what you need and we'll get right back to you.</p>
        <div class="hero-cta">
          <a href={`tel:${business?.phone}`} class="btn btn-primary">Call {business?.phone}</a>
          <a href={`mailto:${business?.email}`} class="btn btn-ghost">Email Us</a>
        </div>
      </div>
      <div class="hero-art" data-reveal>
        <img src="/art-contact.png" alt="Call Freight Bridge for a quote" width="900" height="680" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="contact-layout">
      <div class="panel" data-reveal>
        <h2 class="form-title">Send us a message</h2>
        <form id="contact-form">
          <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
          <input type="hidden" name="from_name" value={`${business?.name} website`} />
          <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />
          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" placeholder="(555) 123-4567" />
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <select id="subject" name="subject">
                <option value="">Select a subject</option>
                <option value="quote">Request a Quote</option>
                <option value="residential-moving">Residential & Furniture Moving</option>
                <option value="commercial-moving">Commercial & Office Moving</option>
                <option value="freight-hauling">Nationwide Freight Hauling</option>
                <option value="data-center-hauling">Data Center Hauling</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about your move or load..." required></textarea>
          </div>
          <button type="submit" class="btn btn-blue submit-btn">Send Message</button>
          <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
        </form>
      </div>

      <aside class="contact-info" data-reveal>
        <div class="info-card">
          <h3>Get in touch</h3>
          <div class="info-item"><span class="info-icon">📍</span><div><strong>Address</strong><p>{business?.address.city}, {business?.address.state} {business?.address.zip}</p></div></div>
          <div class="info-item"><span class="info-icon">📞</span><div><strong>Phone</strong><p><a href={`tel:${business?.phone}`}>{business?.phone}</a></p></div></div>
          <div class="info-item"><span class="info-icon">✉️</span><div><strong>Email</strong><p><a href={`mailto:${business?.email}`}>{business?.email}</a></p></div></div>
        </div>
        <div class="info-card">
          <h3>Business hours</h3>
          <div class="hours-row"><span>Monday – Friday</span><span>8:00 AM – 6:00 PM CT</span></div>
          <div class="hours-row"><span>Saturday</span><span>By appointment</span></div>
          <div class="hours-row closed"><span>Sunday</span><span>Closed</span></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal>
      <span class="kicker">Why people call us</span>
      <h2>Trusted across the Midwest</h2>
      <p class="section-sub">Rated {avgRating} out of 5 across {reviews.length} reviews — and you'll talk to {business?.owner} directly, not a call center.</p>
    </div>
    <div class="review-grid" data-reveal>
      {contactReviews.map((r) => (
        <figure class="review-card">
          <div class="stars" aria-label={`${r.rating} out of 5 stars`}>{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</div>
          <blockquote>“{r.review}”</blockquote>
          <figcaption><strong>{r.name}</strong> · {r.location}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      const key = form.querySelector('input[name="access_key"]')?.value;

      if (!key || key === 'YOUR_WEB3FORMS_ACCESS_KEY') {
        status.textContent = 'Form not configured yet — add your Web3Forms access key.';
        status.className = 'form-status error';
        return;
      }

      btn.disabled = true;
      status.textContent = 'Sending…';
      status.className = 'form-status';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json();
        if (data.success) {
          form.reset();
          status.textContent = 'Thanks! We got your message and will be in touch shortly.';
          status.className = 'form-status success';
        } else {
          status.textContent = data.message || 'Something went wrong — please call or email us.';
          status.className = 'form-status error';
        }
      } catch {
        status.textContent = 'Network error — please call or email us instead.';
        status.className = 'form-status error';
      }
      btn.disabled = false;
    });
  </script>
</Base>

<style>
  .contact-layout { display: grid; grid-template-columns: 1fr 360px; gap: 1.5rem; }
  @media (max-width: 820px) { .contact-layout { grid-template-columns: 1fr; } }
  .form-title { font-family: var(--font-head); color: var(--ink); margin: 0 0 1.5rem; font-size: 1.4rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 520px) { .form-row { grid-template-columns: 1fr; } }
  .form-group { margin-bottom: 1.1rem; }
  label { display: block; margin-bottom: 0.4rem; font-weight: 600; font-size: 0.85rem; color: var(--ink); }
  input, select, textarea {
    width: 100%; padding: 0.7rem 0.85rem; border: 1px solid var(--line); border-radius: var(--r);
    font-size: 0.95rem; font-family: inherit; background: #fff; box-sizing: border-box; color: var(--ink);
  }
  input:focus, select:focus, textarea:focus {
    outline: none; border-color: var(--blue); box-shadow: 0 0 0 4px rgba(37,99,235,0.12);
  }
  textarea { resize: vertical; }
  .submit-btn { width: 100%; justify-content: center; border: none; cursor: pointer; font-size: 1rem; }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .hp { display: none !important; }
  .form-status { margin: 1rem 0 0; font-size: 0.9rem; font-weight: 500; }
  .form-status:empty { display: none; }
  .form-status.success { color: #047857; }
  .form-status.error { color: #b91c1c; }
  .contact-info { display: flex; flex-direction: column; gap: 1.25rem; }
  .info-card { background: #fff; border: 1px solid var(--line); padding: 1.5rem; border-radius: var(--r-lg); box-shadow: var(--shadow-sm); }
  .info-card h3 { margin: 0 0 1rem; color: var(--navy); font-size: 1.05rem; font-family: var(--font-head); }
  .info-item { display: flex; gap: 0.75rem; margin-bottom: 1rem; }
  .info-item:last-child { margin-bottom: 0; }
  .info-icon { font-size: 1.25rem; flex-shrink: 0; }
  .info-item strong { display: block; font-size: 0.75rem; text-transform: uppercase; color: var(--muted); margin-bottom: 0.2rem; letter-spacing: 0.04em; }
  .info-item p { margin: 0; color: var(--ink); line-height: 1.4; }
  .info-item a { color: var(--blue); text-decoration: none; }
  .hours-row { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--line); font-size: 0.9rem; color: var(--ink); }
  .hours-row:last-child { border-bottom: none; }
  .hours-row.closed { color: var(--muted); }
</style>
