---
import Base from '@engine/layouts/Base.astro';
import { getEntry } from 'astro:content';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
---

<Base title={`Contact Us | ${business?.name}`} description={`Get in touch with ${business?.name}. Request a quote for moving, nationwide freight hauling, or data center hauling.`}>
  <section class="hero">
    <h1>Contact Us</h1>
    <p class="subtitle">Need a move or a load hauled? Tell us what you need and we'll get you a straight quote.</p>
  </section>

  <div class="contact-layout">
    <section class="contact-form">
      <h2>Send Us a Message</h2>
      <form id="quote-form">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="(555) 123-4567" />
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <select id="subject" name="subject">
              <option value="">Select a subject</option>
              <option value="quote">Request a Quote</option>
              <option value="residential-moving">Residential & Furniture Moving</option>
              <option value="commercial-moving">Commercial & Office Moving</option>
              <option value="freight-hauling">Nationwide Freight Hauling</option>
              <option value="data-center-hauling">Data Center Hauling</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="Tell us about your logistics needs..." required></textarea>
        </div>
        <button type="submit" class="submit-btn">Send Message</button>
        <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <aside class="contact-info">
      <div class="info-card">
        <h3>Get In Touch</h3>
        <div class="info-item">
          <span class="info-icon">📍</span>
          <div>
            <strong>Address</strong>
            <p>{business?.address.street}<br />{business?.address.city}, {business?.address.state} {business?.address.zip}</p>
          </div>
        </div>
        <div class="info-item">
          <span class="info-icon">📞</span>
          <div>
            <strong>Phone</strong>
            <p><a href={`tel:${business?.phone}`}>{business?.phone}</a></p>
          </div>
        </div>
        <div class="info-item">
          <span class="info-icon">✉️</span>
          <div>
            <strong>Email</strong>
            <p><a href={`mailto:${business?.email}`}>{business?.email}</a></p>
          </div>
        </div>
      </div>

      <div class="info-card">
        <h3>Business Hours</h3>
        <div class="hours">
          <div class="hours-row">
            <span>Monday - Friday</span>
            <span>8:00 AM - 6:00 PM CT</span>
          </div>
          <div class="hours-row">
            <span>Saturday</span>
            <span>By appointment</span>
          </div>
          <div class="hours-row closed">
            <span>Sunday</span>
            <span>Closed</span>
          </div>
        </div>
      </div>


    </aside>
  </div>

  <script>
    import { supabase } from '../db/supabase.js';

    const form = document.getElementById('quote-form');
    const status = document.getElementById('form-status');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      const fd = new FormData(form);
      const payload = {
        name: fd.get('name'),
        email: fd.get('email'),
        phone: fd.get('phone') || null,
        subject: fd.get('subject') || null,
        message: fd.get('message'),
      };

      btn.disabled = true;
      status.textContent = 'Sending…';
      status.className = 'form-status';

      const { error } = await supabase.from('quote_requests').insert(payload);

      if (error) {
        console.error(error);
        status.textContent = 'Something went wrong — please call us or try again.';
        status.classList.add('error');
      } else {
        form.reset();
        status.textContent = 'Thanks! We got your request and will be in touch shortly.';
        status.classList.add('success');
      }
      btn.disabled = false;
    });
  </script>
</Base>

<style>
  .hero {
    padding: 4rem 0 2rem;
    text-align: center;
  }
  h1 {
    font-size: 2.5rem;
    margin: 0 0 1rem;
    color: #1e3a8a;
  }
  .subtitle {
    font-size: 1.2rem;
    color: #6b7280;
    margin: 0;
  }
  h2 {
    font-size: 1.5rem;
    margin: 0 0 1.5rem;
    color: #111827;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 2rem;
    padding: 2rem 0;
  }
  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }

  .contact-form {
    background: #f9fafb;
    padding: 2rem;
    border-radius: 0.75rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 520px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
  .form-group {
    margin-bottom: 1.25rem;
  }
  label {
    display: block;
    margin-bottom: 0.375rem;
    font-weight: 600;
    font-size: 0.875rem;
    color: #374151;
  }
  input, select, textarea {
    width: 100%;
    padding: 0.625rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.95rem;
    font-family: inherit;
    background: white;
    box-sizing: border-box;
  }
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }
  textarea {
    resize: vertical;
  }
  .submit-btn {
    background: #2563eb;
    color: white;
    padding: 0.75rem 2rem;
    border: none;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    width: 100%;
  }
  .submit-btn:hover {
    background: #1e40af;
  }
  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .form-status {
    margin: 1rem 0 0;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .form-status:empty {
    display: none;
  }
  .form-status.success {
    color: #047857;
  }
  .form-status.error {
    color: #b91c1c;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .info-card {
    background: white;
    border: 1px solid #e5e7eb;
    padding: 1.5rem;
    border-radius: 0.75rem;
  }
  .info-card h3 {
    margin: 0 0 1rem;
    color: #1e3a8a;
    font-size: 1.1rem;
  }
  .info-item {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .info-item:last-child {
    margin-bottom: 0;
  }
  .info-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  .info-item strong {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    color: #6b7280;
    margin-bottom: 0.25rem;
  }
  .info-item p {
    margin: 0;
    color: #374151;
    line-height: 1.4;
  }
  .info-item a {
    color: #2563eb;
    text-decoration: none;
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f3f4f6;
    font-size: 0.9rem;
    color: #374151;
  }
  .hours-row:last-child {
    border-bottom: none;
  }
  .hours-row.closed {
    color: #9ca3af;
  }

</style>
