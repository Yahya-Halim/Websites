---
import Base from '@engine/layouts/Base.astro';
import { getEntry } from 'astro:content';
import reviews from '/src/data/content/reviews.json';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

const aboutReviews = reviews.slice(0, 6);
const avgRating = (reviews.reduce((a, r) => a + r.rating, 0) / reviews.length).toFixed(1);
---

<Base title={`About Us | ${business?.name}`} description={`Learn about ${business?.name}, a trusted moving and freight hauling company in ${business?.address.city}, ${business?.address.state}, with a team that treats every load like their own.`}>
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">About {business?.name}</span>
        <h1>A team that moves <span class="grad">like it's their own.</span></h1>
        <p class="lead">{business?.tagline}</p>
        <div class="hero-cta">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href="/services" class="btn btn-ghost">Our Services</a>
        </div>
      </div>
      <div class="hero-art" data-reveal>
        <img src="/art-about.png" alt="Freight Bridge moving trucks and cargo vans" width="900" height="680" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="panel" data-reveal style="max-width:52rem;margin:0 auto;">
      <span class="kicker">Our story</span>
      <h2 style="font-family:var(--font-head);color:var(--ink);margin:.5rem 0 1rem;">Built on doing it right</h2>
      <p style="color:var(--muted);line-height:1.8;margin:0 0 1rem;">
        {business?.name} is a trusted moving and freight hauling company based in
        {business?.address.city}, {business?.address.state}. Founded in 2020 by owner {business?.owner}, we built this company on a simple principle: treat every move and every haul like it's our own. We're not a national chain or a call center — when you hire us, you work with a dedicated, experienced team that handles your job from quote to completion and stands behind every load.
      </p>
      <p style="color:var(--muted);line-height:1.8;margin:0 0 1rem;">
        We move households and businesses across state lines, haul freight in 49 states for brokers and dispatchers with our own truck, and provide post-construction hauling for data center projects across the Iowa City and Cedar Rapids corridor. With over 500 completed moves, licensed interstate authority (USDOT {business?.dotNumber} / MC {business?.mcNumber}), and full cargo and liability insurance, we bring the credentials and experience to handle jobs of any size.
      </p>
      <p style="color:var(--muted);line-height:1.8;margin:0;">
        Our service area covers the Iowa City–Cedar Rapids corridor for local moves — Iowa City, Coralville, North Liberty, and Cedar Rapids — plus 49 states for freight hauling. We offer same-day quotes, competitive rates, and scheduling that works around your business hours. Payment options include credit card, wire transfer, ACH, and Net-30 invoicing for commercial clients.
      </p>
    </div>
  </section>

  <section class="section" style="margin:3rem 0;">
    <div class="stats-bar" data-reveal>
      <div class="stat">
        <div class="stat-num">500+</div>
        <div class="stat-label">Moves Completed</div>
      </div>
      <div class="stat">
        <div class="stat-num">50</div>
        <div class="stat-label">States Served</div>
      </div>
      <div class="stat">
        <div class="stat-num">5+</div>
        <div class="stat-label">Years in Business</div>
      </div>
      <div class="stat">
        <div class="stat-num">{business?.dotNumber}</div>
        <div class="stat-label">USDOT Number</div>
      </div>
      <div class="stat">
        <div class="stat-num">{business?.mcNumber}</div>
        <div class="stat-label">MC Authority</div>
      </div>
    </div>
  </section>

  <section class="section" style="margin:2rem 0 3rem;">
    <div class="trust-bar" data-reveal>
      <span class="trust-item"><span class="badge">✓</span> Licensed Interstate Carrier</span>
      <span class="trust-item"><span class="badge">✓</span> Full Insurance Coverage</span>
      <span class="trust-item"><span class="badge">✓</span> BBB Accredited</span>
      <span class="trust-item"><span class="badge">✓</span> Same-Day Quotes</span>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal>
      <span class="kicker">What we stand for</span>
      <h2>Values that ride along</h2>
    </div>
    <div class="grid-3">
      <div class="why" data-reveal><span class="why-num">01</span><h3>Hands-On Service</h3><p>Our team is on every job — people who know your move from start to finish, not a faceless call center.</p></div>
      <div class="why" data-reveal><span class="why-num">02</span><h3>Honest & Reliable</h3><p>Straight quotes, careful handling of your belongings, and no surprises on moving day.</p></div>
      <div class="why" data-reveal><span class="why-num">03</span><h3>Local to Nationwide</h3><p>From a single piece of furniture across Iowa to freight in 49 states — we go wherever you're headed.</p></div>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal>
      <span class="kicker">Our team</span>
      <h2>The Freight Bridge crew</h2>
      <p class="section-sub">Movers · Haulers · Drivers — {business?.name} was founded to do moving and hauling the way it should be done: hands-on, dependable, and personal. Our experienced crew handles the quotes, runs the jobs, and stands behind every load.</p>
    </div>
    <div class="panel" data-reveal style="max-width:52rem;margin:1.5rem auto 0;">
      <p style="color:var(--muted);line-height:1.8;margin:0;">
        <strong>Owner & Operator: {business?.owner}</strong> — With over five years in the moving and freight industry, {business?.owner} leads every job personally. From the initial quote to the final placement of your furniture or delivery of your freight, you deal directly with the owner. That means no call-center transfers, no third-party subcontractors, and no surprises. Mohamed and the Freight Bridge crew have completed over 500 moves and hauled freight across 49 states, building a reputation for reliability, careful handling, and honest communication in the Iowa City–Cedar Rapids corridor and beyond.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="owner-note" data-reveal>
      <p>
        “We started with one truck and local moves around Iowa City. Now we run freight in 49 states and
        we've got over 500 moves behind us — but the part that matters hasn't changed. We answer the phone,
        we show up when we say we will, and we treat your stuff like it's ours. That's the whole company.”
      </p>
      <cite>— {business?.owner}, Owner &amp; Operator, Freight Bridge LLC</cite>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal>
      <span class="kicker">Reviews</span>
      <h2>What our customers say</h2>
      <p class="section-sub">Rated {avgRating} out of 5 across {reviews.length} reviews.</p>
    </div>
    <div class="review-grid" data-reveal>
      {aboutReviews.map((r) => (
        <figure class="review-card">
          <div class="stars" aria-label={`${r.rating} out of 5 stars`}>{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</div>
          <blockquote>“{r.review}”</blockquote>
          <figcaption><strong>{r.name}</strong> · {r.location}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="cta">
    <div class="cta-bg" aria-hidden="true"></div>
    <h2>Ready to work with us?</h2>
    <p>Get a straight quote on your move, haul, or freight needs.</p>
    <div class="hero-cta">
      <a href="/contact" class="btn btn-primary">Get a Quote</a>
      <a href={`tel:${business?.phone}`} class="btn btn-ghost-light">Call {business?.phone}</a>
    </div>
  </section>
</Base>
