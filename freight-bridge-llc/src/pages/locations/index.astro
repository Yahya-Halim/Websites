---
import Base from '@engine/layouts/Base.astro';
import { getEntry, getCollection } from 'astro:content';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
const locations = await getCollection('locations');

// Group locations by state
const byState: Record<string, typeof locations> = {};
for (const loc of locations) {
  const state = loc.data.state;
  if (!byState[state]) byState[state] = [];
  byState[state].push(loc);
}
const states = Object.keys(byState).sort();
const stateCount = states.length;
const cityCount = locations.length;

const title = `Service Areas | ${business?.name}`;
const description = `${business?.name} serves ${cityCount} cities across ${stateCount} states for moving and freight hauling. Get a free quote.`;
---

<Base title={title} description={description}>
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">Service areas</span>
        <h1>Local roots, <span class="grad">interstate reach.</span></h1>
        <p class="lead">Based in the Iowa City–Cedar Rapids corridor, with licensed interstate service for long-distance moves.</p>
        <div class="hero-cta"><a href="/contact" class="btn btn-primary">Get a Quote</a></div>
      </div>
      <div class="hero-art" data-reveal>
        <img src="/art-locations.png" alt="USA map showing Freight Bridge service areas" width="900" height="680" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal>
      <span class="kicker">Coverage</span>
      <h2>{cityCount} cities across {stateCount} states</h2>
      <p class="section-sub">Filter by state or search for your city.</p>
    </div>

    {/* Search bar */}
    <div class="filter-bar" data-reveal>
      <input
        type="text"
        id="city-search"
        placeholder="Search for a city..."
        class="search-input"
        autocomplete="off"
      />
      <div class="filter-count">
        <span id="city-count">{cityCount}</span> cities
      </div>
    </div>

    {/* State filter buttons */}
    <div class="state-filters" data-reveal>
      <button class="filter-btn active" data-state="all">All States</button>
      {states.map((state) => (
        <button class="filter-btn" data-state={state}>
          {state} ({byState[state].length})
        </button>
      ))}
    </div>

    {/* City grid */}
    <div class="grid-3" id="city-grid">
      {locations.map((location) => (
        <a
          class="card city-card"
          href={`/locations/${location.data.slug}`}
          data-reveal
          data-state={location.data.state}
          data-city={location.data.city.toLowerCase()}
        >
          <div class="city-img-wrap">
            <img
              src={`/images/cities/${location.data.slug}.png`}
              alt={`${location.data.city}, ${location.data.stateAbbr || location.data.state}`}
              width="400"
              height="250"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="city-card-body">
            <h3>{location.data.city}, {location.data.stateAbbr || location.data.state}</h3>
            <ul class="pill-list" style="margin:0 0 0.6rem;">
              {location.data.servicesOffered.map((s) => (<li>{s.replace(/-/g, ' ')}</li>))}
            </ul>
            <span class="card-link">View {location.data.city} <span class="arrow">→</span></span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="panel" data-reveal style="max-width:52rem;margin:0 auto;text-align:center;">
      <span class="kicker">Coverage</span>
      <h2 style="font-family:var(--font-head);color:var(--ink);margin:.5rem 0 1rem;">Local roots, interstate reach</h2>
      <p style="color:var(--muted);line-height:1.8;margin:0;">
        {business?.name} is based in {business?.address.city}, Iowa, serving the surrounding corridor —
        Coralville, North Liberty, and Cedar Rapids — for moving and freight hauling. We also haul
        freight and handle long-distance moves in 49 states.
      </p>
    </div>
  </section>

  <section class="cta">
    <div class="cta-bg" aria-hidden="true"></div>
    <h2>Need a mover or hauler in your area?</h2>
    <p>Contact {business?.name} for a straight quote on your move or freight needs.</p>
    <div class="hero-cta">
      <a href="/contact" class="btn btn-primary">Get a Quote</a>
      <a href={`tel:${business?.phone}`} class="btn btn-ghost-light">Call {business?.phone}</a>
    </div>
  </section>

  <script is:inline>
    (function() {
      const searchInput = document.getElementById('city-search');
      const cityGrid = document.getElementById('city-grid');
      const cityCards = cityGrid.querySelectorAll('.city-card');
      const countDisplay = document.getElementById('city-count');
      const filterButtons = document.querySelectorAll('.filter-btn');
      let activeState = 'all';

      function updateFilter() {
        const query = searchInput.value.toLowerCase().trim();
        let visible = 0;

        cityCards.forEach((card) => {
          const state = card.dataset.state;
          const city = card.dataset.city;
          const matchesState = activeState === 'all' || state === activeState;
          const matchesSearch = !query || city.includes(query) || state.toLowerCase().includes(query);

          if (matchesState && matchesSearch) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });

        countDisplay.textContent = visible;
      }

      searchInput.addEventListener('input', updateFilter);

      filterButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          filterButtons.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          activeState = btn.dataset.state;
          updateFilter();
        });
      });
    })();
  </script>

  <style>
    .filter-bar {
      display: flex;
      align-items: center;
      gap: 1rem;
      max-width: 48rem;
      margin: 0 auto 2rem;
      padding: 0 1rem;
    }
    .search-input {
      flex: 1;
      padding: 0.75rem 1.25rem;
      border-radius: 999px;
      border: 1.5px solid var(--line);
      font-size: 1rem;
      font-family: var(--font-body);
      color: var(--ink);
      background: #fff;
      outline: none;
      transition: border-color 0.2s ease;
    }
    .search-input:focus {
      border-color: var(--blue);
    }
    .filter-count {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--muted);
      white-space: nowrap;
    }
    .state-filters {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      max-width: 58rem;
      margin: 0 auto 2.5rem;
      padding: 0 1rem;
    }
    .filter-btn {
      padding: 0.4rem 1rem;
      border-radius: 999px;
      border: 1.5px solid var(--line);
      background: #fff;
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s ease;
      font-family: var(--font-body);
    }
    .filter-btn:hover {
      border-color: var(--blue);
      color: var(--blue);
    }
    .filter-btn.active {
      background: var(--blue);
      border-color: var(--blue);
      color: #fff;
    }
    .city-card {
      overflow: hidden;
      padding: 0;
    }
    .city-img-wrap {
      width: 100%;
      aspect-ratio: 16 / 10;
      overflow: hidden;
      background: var(--surface);
    }
    .city-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }
    .city-card:hover .city-img-wrap img {
      transform: scale(1.05);
    }
    .city-card-body {
      padding: 1.5rem;
    }
    .city-card-body h3 {
      font-size: 1.15rem;
      margin: 0 0 0.6rem;
      color: var(--navy);
    }
  </style>
</Base>
