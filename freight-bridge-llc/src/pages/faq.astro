---
import Base from '@engine/layouts/Base.astro';
import { getEntry } from 'astro:content';
import faqs from '/src/data/content/faqs.json';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
const base = business?.domain ?? '';

const title = `Moving & Freight FAQ | ${business?.name}`;
const description =
  'Answers to common questions about Freight Bridge LLC — moving costs in Iowa, interstate freight, licensing (USDOT 4166904 / MC 1734786), service areas, scheduling, and more.';

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${base}/` },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${base}/faq` },
  ],
};
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">Questions & answers</span>
        <h1>Moving & freight, <span class="grad">answered straight.</span></h1>
        <p class="lead">
          The questions customers actually ask {business?.owner} — about pricing, licensing, service
          areas, and how an owner-operated carrier out of Iowa City does the job differently.
        </p>
        <div class="hero-cta">
          <a href="/contact" class="btn btn-primary">Get a Quote</a>
          <a href={`tel:${business?.phone}`} class="btn btn-ghost">Call {business?.phone}</a>
        </div>
      </div>
      <div class="hero-art" data-reveal>
        <img src="/art-contact.png" alt="Call Freight Bridge for a quote" width="900" height="680" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="faq-list" data-reveal style="max-width:52rem;">
      {faqs.map((faq) => (
        <details class="faq-item">
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="panel" data-reveal style="max-width:52rem;margin:0 auto;text-align:center;">
      <span class="kicker">Still have a question?</span>
      <h2 style="font-family:var(--font-head);color:var(--ink);margin:.5rem 0 1rem;">Ask us directly</h2>
      <p style="color:var(--muted);line-height:1.8;margin:0;">
        If your question isn't here, call {business?.owner} at <a href={`tel:${business?.phone}`}>{business?.phone}</a>{' '}
        or <a href="/contact">send us a message</a>. You'll get a straight answer from the person who runs the
        trucks — usually the same day. You can also browse <a href="/services">our services</a>,{' '}
        <a href="/locations">service areas</a>, or our <a href="/blog">moving & freight guides</a>.
      </p>
    </div>
  </section>

  <section class="cta">
    <div class="cta-bg" aria-hidden="true"></div>
    <h2>Ready to get a quote?</h2>
    <p>Tell us about your move or load and we'll get you a straight number — fast.</p>
    <div class="hero-cta">
      <a href="/contact" class="btn btn-primary">Get a Quote</a>
      <a href={`tel:${business?.phone}`} class="btn btn-ghost-light">Call {business?.phone}</a>
    </div>
  </section>
</Base>
