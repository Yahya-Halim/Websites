---
import Base from '@engine/layouts/Base.astro';
import { getEntry } from 'astro:content';
import reviews from '/src/data/content/reviews.json';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

const dcReviews = reviews.slice(3, 6);
const avgRating = (reviews.reduce((a, r) => a + r.rating, 0) / reviews.length).toFixed(1);

const faqs = [
  { question: 'What types of construction debris do you remove?', answer: 'Concrete waste, scrap metal, wood, drywall, insulation, packaging materials, cable spools, and general construction debris from data center sites.' },
  { question: 'Do you handle hazardous materials?', answer: 'No. We focus on standard construction debris and non-hazardous waste removal only.' },
  { question: 'Can you handle large-volume cleanups?', answer: 'Yes. We coordinate multi-trip removal schedules for large projects and work around your construction timeline.' },
  { question: 'Do you provide data destruction for decommissioned equipment?', answer: 'We focus on physical removal and transport. We can deliver equipment to your certified ITAD or e-waste recycling partner.' },
];

const base = business?.domain ?? '';
const pageUrl = `${base}/services/data-center-iowa-city`;

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Data Center Cleanup & Removal — Iowa City',
  description: 'Post-construction debris removal, equipment hauling, and site cleanup for data center projects in the Iowa City corridor.',
  serviceType: 'Post-construction hauling',
  url: pageUrl,
  provider: { '@type': 'LocalBusiness', '@id': `${base}/#business`, name: business?.name, telephone: business?.phone },
  areaServed: ['Iowa City', 'Coralville', 'North Liberty'].map((name) => ({ '@type': 'City', name })),
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${base}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${base}/services` },
    { '@type': 'ListItem', position: 3, name: 'Data-Center Hauling — Iowa City', item: pageUrl },
  ],
};
---

<Base title="Data Center Cleanup & Removal — Iowa City | Freight Bridge LLC" description="Post-construction debris removal, equipment hauling, and site cleanup for data center projects in the Iowa City corridor. Handled by the Freight Bridge LLC team.">
  <script type="application/ld+json" set:html={JSON.stringify(serviceLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">Iowa City Corridor</span>
        <h1>Data-center <span class="grad">cleanup & removal.</span></h1>
        <p class="lead">Post-construction hauling for data center projects in Iowa City, Coralville, and North Liberty.</p>
        <div class="hero-cta">
          <a href={`tel:${business?.phone}`} class="btn btn-primary">Call {business?.phone}</a>
          <a href="/contact" class="btn btn-ghost">Request a Quote</a>
        </div>
      </div>
      <div class="hero-art" data-reveal>
        <img src="/art-datacenter.png" alt="Warehouse and industrial facility" width="900" height="680" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="panel" data-reveal style="max-width:52rem;margin:0 auto;">
      <p style="color:var(--muted);line-height:1.8;margin:0;font-size:1.05rem;">
        Freight Bridge LLC provides hands-on, professionally supervised post-construction cleanup and
        removal for data center construction projects across the Iowa City corridor. We don't deliver
        building materials — we haul out what's left after the build is done. Debris, decommissioned
        equipment, packaging, scrap — our crew loads it, trucks it, and gets your site ready for commissioning.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">What we haul out</span><h2>Built for data-center scale</h2></div>
    <div class="grid-3">
      <div class="card" data-reveal><h3>🏗️ Construction Debris Removal</h3><p>Concrete waste, scrap metal, wood, drywall, insulation, packaging, cable spools, and general construction debris from build sites.</p></div>
      <div class="card" data-reveal><h3>🖥️ Equipment Hauling</h3><p>Old server racks, cooling units, UPS systems, PDUs, cable trays, raised floor tiles, and obsolete infrastructure — delivered to your ITAD or recycler.</p></div>
      <div class="card" data-reveal><h3>🧹 Site Cleanup</h3><p>Final-phase material clearing after buildout, coordinated with your project timeline so runs don't disrupt active work zones.</p></div>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">Service area</span><h2>Where we work</h2></div>
    <div class="grid-3">
      <div class="why" data-reveal><h3>Iowa City</h3><p>All services available</p></div>
      <div class="why" data-reveal><h3>Coralville</h3><p>Debris removal & site cleanup</p></div>
      <div class="why" data-reveal><h3>North Liberty</h3><p>Debris removal & site cleanup</p></div>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">Why us</span><h2>Why Freight Bridge for data-center cleanup?</h2></div>
    <div class="grid-2">
      <div class="why" data-reveal><h3>A team on every job</h3><p>Our crew supervises every load with care. No middlemen, no surprises.</p></div>
      <div class="why" data-reveal><h3>Local to the corridor</h3><p>Based in Iowa City — we can be on-site within hours, not days.</p></div>
      <div class="why" data-reveal><h3>Works around your schedule</h3><p>We coordinate directly with site managers to fit removal runs into your construction phases.</p></div>
      <div class="why" data-reveal><h3>No hazmat, no hassle</h3><p>Standard construction debris and non-hazardous equipment removal. Clean, simple, reliable.</p></div>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">FAQ</span><h2>Frequently asked questions</h2></div>
    <div class="faq-list" data-reveal>
      {faqs.map((faq) => (
        <details class="faq-item"><summary>{faq.question}</summary><p>{faq.answer}</p></details>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">Reviews</span><h2>What our customers say</h2><p class="section-sub">Rated {avgRating} out of 5 across {reviews.length} reviews.</p></div>
    <div class="review-grid" data-reveal>
      {dcReviews.map((r) => (
        <figure class="review-card">
          <div class="stars" aria-label={`${r.rating} out of 5 stars`}>{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</div>
          <blockquote>“{r.review}”</blockquote>
          <figcaption><strong>{r.name}</strong> · {r.location}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="cta">
    <div class="cta-bg" aria-hidden="true"></div>
    <h2>Need post-construction hauling in Iowa City?</h2>
    <p>Call us directly — our team will coordinate the removal around your project timeline.</p>
    <div class="hero-cta">
      <a href={`tel:${business?.phone}`} class="btn btn-primary">Call {business?.phone}</a>
      <a href="/contact" class="btn btn-ghost-light">Request a Quote</a>
    </div>
  </section>
</Base>
