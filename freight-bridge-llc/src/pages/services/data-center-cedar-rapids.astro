---
import Base from '@engine/layouts/Base.astro';
import { getEntry } from 'astro:content';
import reviews from '/src/data/content/reviews.json';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;

const dcReviews = reviews.slice(0, 3);
const avgRating = (reviews.reduce((a, r) => a + r.rating, 0) / reviews.length).toFixed(1);

const faqs = [
  { question: 'Do you service the Big Cedar Industrial Center?', answer: 'Yes. We provide debris removal, equipment hauling, and site cleanup for projects at Big Cedar Industrial Center and throughout the Cedar Rapids metro area.' },
  { question: 'Can you work with QTS or Google project timelines?', answer: 'Absolutely. Our team coordinates directly with site managers to schedule removal runs that fit your project phases.' },
  { question: 'Do you handle hazardous materials?', answer: 'No. We focus on standard construction debris and non-hazardous waste removal only.' },
  { question: 'How quickly can you respond?', answer: "We're based in the Iowa City–Cedar Rapids corridor. Our crew can be on-site within hours for urgent cleanup needs." },
  { question: 'Do you provide data destruction for decommissioned equipment?', answer: 'We focus on physical removal and transport. We deliver equipment to your certified ITAD or e-waste recycling partner.' },
];

const base = business?.domain ?? '';
const pageUrl = `${base}/services/data-center-cedar-rapids`;

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Data Center Cleanup & Removal — Cedar Rapids',
  description: 'Post-construction debris removal and equipment hauling for data center projects in Cedar Rapids, including Big Cedar Industrial Center.',
  serviceType: 'Post-construction hauling',
  url: pageUrl,
  provider: { '@type': 'LocalBusiness', '@id': `${base}/#business`, name: business?.name, telephone: business?.phone },
  areaServed: ['Cedar Rapids', 'Marion', 'Hiawatha'].map((name) => ({ '@type': 'City', name })),
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${base}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${base}/services` },
    { '@type': 'ListItem', position: 3, name: 'Data-Center Hauling — Cedar Rapids', item: pageUrl },
  ],
};
---

<Base title="Data Center Cleanup & Removal — Cedar Rapids | Freight Bridge LLC" description="Post-construction debris removal and equipment hauling for data center projects in Cedar Rapids. Serving Big Cedar Industrial Center, QTS, and Google campuses.">
  <script type="application/ld+json" set:html={JSON.stringify(serviceLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">Cedar Rapids Corridor</span>
        <h1>Data-center <span class="grad">cleanup & removal.</span></h1>
        <p class="lead">Post-construction hauling for Cedar Rapids — serving Big Cedar Industrial Center and beyond.</p>
        <div class="hero-cta">
          <a href={`tel:${business?.phone}`} class="btn btn-primary">Call {business?.phone}</a>
          <a href="/contact" class="btn btn-ghost">Request a Quote</a>
        </div>
      </div>
      <div class="hero-art" data-reveal>
        <img src="/art-datacenter.png" alt="Warehouse and industrial facility" width="900" height="680" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="panel" data-reveal style="max-width:52rem;margin:0 auto;">
      <p style="color:var(--muted);line-height:1.8;margin:0;font-size:1.05rem;">
        Cedar Rapids is the epicenter of Iowa's data center boom — with billions in investment from
        QTS, Google, and others at Big Cedar Industrial Center. Freight Bridge LLC provides the
        post-construction muscle: hauling out debris, removing decommissioned equipment, and cleaning
        up sites so they're ready for commissioning. Our crew supervises every load with care.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">What we haul out</span><h2>Built for campus-scale projects</h2></div>
    <div class="grid-3">
      <div class="card" data-reveal><h3>🏗️ Construction Debris Removal</h3><p>Concrete waste, scrap metal, wood, drywall, insulation, packaging, and general debris from build sites at Big Cedar Industrial Center and throughout Cedar Rapids.</p></div>
      <div class="card" data-reveal><h3>🖥️ Equipment Hauling</h3><p>Server racks, cooling units, UPS systems, PDUs, cable trays, and obsolete infrastructure, transported to your certified ITAD or recycling facility.</p></div>
      <div class="card" data-reveal><h3>🧹 Site Cleanup</h3><p>Final-phase clearing after buildout. We coordinate with QTS, Google, and other project timelines to fit runs around active construction.</p></div>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">Service area</span><h2>Where we work</h2></div>
    <div class="grid-2">
      <div class="dc-card" data-reveal><span class="dc-tag">Featured</span><h3>Big Cedar Industrial Center</h3><p>All services — QTS &amp; Google campuses</p></div>
      <div class="why" data-reveal><h3>Cedar Rapids</h3><p>All services available</p></div>
      <div class="why" data-reveal><h3>Marion</h3><p>Debris removal & site cleanup</p></div>
      <div class="why" data-reveal><h3>Hiawatha</h3><p>Debris removal & site cleanup</p></div>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">Why us</span><h2>Why Freight Bridge for data-center cleanup?</h2></div>
    <div class="grid-2">
      <div class="why" data-reveal><h3>A team on every job</h3><p>Our crew supervises every load with care. No middlemen, no call centers.</p></div>
      <div class="why" data-reveal><h3>25 miles from the action</h3><p>Based in Iowa City, just down I-380 from Cedar Rapids. On-site within the hour.</p></div>
      <div class="why" data-reveal><h3>Built for data-center scale</h3><p>Multi-trip scheduling for large campus projects. We coordinate with your GC's phases.</p></div>
      <div class="why" data-reveal><h3>Clean and simple</h3><p>Standard debris and non-hazardous equipment only. No hazmat complications — just reliable hauling.</p></div>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">FAQ</span><h2>Frequently asked questions</h2></div>
    <div class="faq-list" data-reveal>
      {faqs.map((faq) => (
        <details class="faq-item"><summary>{faq.question}</summary><p>{faq.answer}</p></details>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">Reviews</span><h2>What our customers say</h2><p class="section-sub">Rated {avgRating} out of 5 across {reviews.length} reviews.</p></div>
    <div class="review-grid" data-reveal>
      {dcReviews.map((r) => (
        <figure class="review-card">
          <div class="stars" aria-label={`${r.rating} out of 5 stars`}>{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</div>
          <blockquote>“{r.review}”</blockquote>
          <figcaption><strong>{r.name}</strong> · {r.location}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="cta">
    <div class="cta-bg" aria-hidden="true"></div>
    <h2>Need post-construction hauling in Cedar Rapids?</h2>
    <p>Call us directly — our team will coordinate the removal around your project timeline.</p>
    <div class="hero-cta">
      <a href={`tel:${business?.phone}`} class="btn btn-primary">Call {business?.phone}</a>
      <a href="/contact" class="btn btn-ghost-light">Request a Quote</a>
    </div>
  </section>
</Base>
