---
import Base from '@engine/layouts/Base.astro';
import { getEntry, getCollection } from 'astro:content';
import reviews from '/src/data/content/reviews.json';

const businessEntry = await getEntry('business', 'biz');
const business = businessEntry?.data;
const services = await getCollection('services');

const idxReviews = reviews.slice(0, 3);
const avgRating = (reviews.reduce((a, r) => a + r.rating, 0) / reviews.length).toFixed(1);

const iconFor: Record<string, string> = {
  'residential-moving': 'home',
  'commercial-moving': 'building',
  'freight-hauling': 'truck',
};
const icons: Record<string, string> = {
  home: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/><path d="M9.5 21v-6h5v6"/></svg>',
  building: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="1.5"/><path d="M8 7h2M14 7h2M8 11h2M14 11h2M8 15h2M14 15h2"/></svg>',
  truck: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h11v9H3z"/><path d="M14 9h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.8"/><circle cx="17.5" cy="18" r="1.8"/></svg>',
};
const icon = (name: string) => icons[name] ?? icons.truck;
---

<Base title={`Our Services | ${business?.name}`} description={`${business?.name} offers residential and commercial moving, nationwide freight hauling, and data center hauling.`}>
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">Our services</span>
        <h1>Moving, freight & <span class="grad">specialty hauling.</span></h1>
        <p class="lead">Everything we do, handled by a team you can trust — from a single sofa to nationwide freight.</p>
        <div class="hero-cta"><a href="/contact" class="btn btn-primary">Get a Quote</a></div>
      </div>
      <div class="hero-art" data-reveal>
        <img src="/art-services.png" alt="Mover with boxes and delivery van" width="900" height="680" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="grid-3">
      {services.map((service) => (
        <a href={`/services/${service.data.slug}`} class="card" data-reveal>
          <span class="card-icon" set:html={icon(iconFor[service.data.slug] ?? 'truck')} />
          <h3>{service.data.name}</h3>
          <p>{service.data.description}</p>
          <span class="card-link">Learn more <span class="arrow">→</span></span>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal>
      <span class="kicker">Specialty</span>
      <h2>Data-center hauling</h2>
      <p class="section-sub">Post-construction cleanup and removal for Iowa's data-center corridor.</p>
    </div>
    <div class="grid-2">
      <a href="/services/data-center-iowa-city" class="dc-card" data-reveal>
        <span class="dc-tag">Iowa City Corridor</span>
        <h3>Iowa City</h3>
        <p>Post-construction debris removal, decommissioned equipment hauling, and site cleanup in Iowa City, Coralville, and North Liberty.</p>
        <span class="card-link">Learn more <span class="arrow">→</span></span>
      </a>
      <a href="/services/data-center-cedar-rapids" class="dc-card" data-reveal>
        <span class="dc-tag">Cedar Rapids Corridor</span>
        <h3>Cedar Rapids</h3>
        <p>Serving Big Cedar Industrial Center and surrounding data center developments — QTS, Google, and more.</p>
        <span class="card-link">Learn more <span class="arrow">→</span></span>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal>
      <span class="kicker">Why Freight Bridge</span>
      <h2>Why customers choose us</h2>
    </div>
    <div class="grid-3">
      <div class="why" data-reveal><span class="why-num">01</span><h3>A team you can trust</h3><p>Our experienced crew handles your job with care — no call centers, no runaround, no surprises.</p></div>
      <div class="why" data-reveal><span class="why-num">02</span><h3>Local to nationwide</h3><p>From local Iowa City moves to freight in 49 states — we go wherever you're headed.</p></div>
      <div class="why" data-reveal><span class="why-num">03</span><h3>Careful handling</h3><p>Your furniture and equipment are loaded, secured, and placed with care on every move.</p></div>
    </div>
  </section>

  <section class="section">
    <div class="section-head" data-reveal><span class="kicker">Reviews</span><h2>What our customers say</h2><p class="section-sub">Rated {avgRating} out of 5 across {reviews.length} reviews.</p></div>
    <div class="review-grid" data-reveal>
      {idxReviews.map((r) => (
        <figure class="review-card">
          <div class="stars" aria-label={`${r.rating} out of 5 stars`}>{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</div>
          <blockquote>“{r.review}”</blockquote>
          <figcaption><strong>{r.name}</strong> · {r.location}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="cta">
    <div class="cta-bg" aria-hidden="true"></div>
    <h2>Ready to get started?</h2>
    <p>Contact us today for a straight quote on your move or freight needs.</p>
    <div class="hero-cta">
      <a href="/contact" class="btn btn-primary">Get a Quote</a>
      <a href={`tel:${business?.phone}`} class="btn btn-ghost-light">Call {business?.phone}</a>
    </div>
  </section>
</Base>
