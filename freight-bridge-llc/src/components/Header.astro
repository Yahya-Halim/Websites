---
import { getEntry } from 'astro:content';

interface Props {
  /** Optional override for the business collection entry id. Defaults to 'biz'. */
  businessId?: string;
}

const { businessId = 'biz' } = Astro.props;
const businessEntry = await getEntry('business', businessId);
const business = businessEntry?.data;
const businessName = business && business.name ? business.name : 'Your Business';
const logoSrc = business?.brand?.logoFilename ? `/${business.brand.logoFilename}` : null;
const logoAlt = business?.brand?.logoAlt ?? businessName;
const siteEntry = await getEntry('site', 'site');
const site = siteEntry?.data;
---

<header class="site-header">
  <div class="nav-inner">
    <a href="/" class="brand">
      {logoSrc && <img class="brand-logo" src={logoSrc} alt={logoAlt} width="150" height="44" />}
      <span class="brand-name">{businessName}</span>
    </a>
    {site?.nav && (
      <>
        <button
          class="nav-toggle"
          type="button"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="site-nav"
        >
          <span class="nav-toggle-box">
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
          </span>
        </button>
        <nav id="site-nav">
          <ul>
            {site.nav.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      </>
    )}
  </div>
</header>

<script>
  const header = document.querySelector('.site-header');
  const onScroll = () => header && header.classList.toggle('is-scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu toggle
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = document.getElementById('site-nav');
  if (toggle && nav) {
    const setOpen = (open: boolean) => {
      nav.classList.toggle('is-open', open);
      toggle.classList.toggle('is-open', open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    };
    toggle.addEventListener('click', () => setOpen(!nav.classList.contains('is-open')));
    // Close after tapping a link, or when resizing up to desktop
    nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    const mq = window.matchMedia('(min-width: 821px)');
    mq.addEventListener('change', (e) => { if (e.matches) setOpen(false); });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }
  .site-header.is-scrolled {
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 12px 34px -16px rgba(19, 26, 92, 0.35);
  }
  .nav-inner {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0.7rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-head, system-ui);
    font-weight: 700;
    font-size: 1.15rem;
    text-decoration: none;
    color: var(--navy, #1e2a8a);
    flex-shrink: 0;
    min-width: 0;
  }
  .brand-logo { height: 42px; width: auto; display: block; flex-shrink: 0; }
  .brand-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  nav { margin-left: auto; }
  nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 1.75rem;
    margin: 0;
    padding: 0;
  }
  nav a {
    text-decoration: none;
    color: var(--ink, #0f172a);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.15s ease;
  }
  nav a:hover { color: var(--blue, #2563eb); }

  /* hamburger button — hidden on desktop */
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin: -0.4rem -0.4rem -0.4rem 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--navy, #1e2a8a);
    cursor: pointer;
    flex-shrink: 0;
  }
  .nav-toggle-box { position: relative; width: 24px; height: 16px; }
  .nav-toggle-bar {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2.5px;
    border-radius: 2px;
    background: currentColor;
    transition: transform 0.25s ease, opacity 0.2s ease, top 0.25s ease;
  }
  .nav-toggle-bar:nth-child(1) { top: 0; }
  .nav-toggle-bar:nth-child(2) { top: 6.75px; }
  .nav-toggle-bar:nth-child(3) { top: 13.5px; }
  .nav-toggle.is-open .nav-toggle-bar:nth-child(1) { top: 6.75px; transform: rotate(45deg); }
  .nav-toggle.is-open .nav-toggle-bar:nth-child(2) { opacity: 0; }
  .nav-toggle.is-open .nav-toggle-bar:nth-child(3) { top: 6.75px; transform: rotate(-45deg); }

  @media (max-width: 820px) {
    .nav-toggle { display: inline-flex; }
    nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      margin: 0;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(14px) saturate(160%);
      -webkit-backdrop-filter: blur(14px) saturate(160%);
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      box-shadow: 0 18px 40px -22px rgba(19, 26, 92, 0.4);
      display: none;
    }
    nav.is-open { display: block; }
    nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      max-width: 76rem;
      margin: 0 auto;
      padding: 0.25rem 1.5rem 0.75rem;
    }
    nav li { border-top: 1px solid rgba(15, 23, 42, 0.07); }
    nav li:first-child { border-top: 0; }
    nav a {
      display: block;
      padding: 0.95rem 0.25rem;
      font-size: 1.02rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-toggle-bar { transition: none; }
  }
</style>
