---
import Header from '@engine/components/Header.astro';
import Footer from '@engine/components/Footer.astro';
import business from '/src/data/business.json';

interface Props {
  title?: string;
  description?: string;
  /** Per-page social-share image (absolute path from site root). Defaults to the site OG card. */
  image?: string;
}

const { title, description, image = '/og-image.png' } = Astro.props;

const pageTitle = title ?? business.name;

const canonicalHref = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;

// Open Graph / Twitter images must be absolute URLs.
const ogImage = Astro.site ? new URL(image, Astro.site).href : image;

// Google Analytics 4 — only render the tag for a real Measurement ID.
const gaId =
  business.analytics?.gaId && business.analytics.gaId !== 'G-PLACEHOLDER'
    ? business.analytics.gaId
    : null;

import localbusinessLd from '/src/content/_generated/localbusiness.jsonld?raw';
import websiteLd from '/src/content/_generated/website.jsonld?raw';

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://freightbridgellc.com/#owner',
  name: business.owner,
  jobTitle: 'Owner & Operator',
  worksFor: { '@id': 'https://freightbridgellc.com/#business' },
  url: 'https://freightbridgellc.com/about',
  sameAs: [
    'https://www.carriersource.io/profile/freight-bridge-llc',
    'https://www.bbb.org/us/ia/iowa-city/profile/moving-companies/freight-bridge-llc-0666-1000063275',
  ],
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${business.domain}/` },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');`} />
      </>
    )}

    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalHref} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content={business.brand.secondaryColor} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${business.name} — ${business.slogan}`} />
    <meta property="og:locale" content="en_US" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={localbusinessLd} />
    <script type="application/ld+json" set:html={websiteLd} />
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      document.documentElement.classList.add('js');
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
    </script>
  </body>
</html>

<style is:global>
  :root {
    --navy: #1e2a8a;
    --navy-deep: #131a5c;
    --blue: #2563eb;
    --red: #e8312a;
    --ink: #0f172a;
    --muted: #64748b;
    --line: #e6e9f2;
    --surface: #f7f9fc;
    --accent-color: var(--blue);

    --grad-brand: linear-gradient(135deg, #2f6bff 0%, #1e2a8a 100%);
    --grad-hero: radial-gradient(120% 140% at 80% 0%, #2b3bd4 0%, #161e6e 45%, #0c1147 100%);
    --grad-red: linear-gradient(135deg, #ff5a4d 0%, #e8312a 100%);

    --r: 14px;
    --r-lg: 22px;
    --shadow-sm: 0 4px 14px rgba(15, 23, 42, 0.08);
    --shadow-lg: 0 24px 60px -20px rgba(19, 26, 92, 0.45);
    --font-head: 'Space Grotesk', system-ui, sans-serif;
    --font-body: 'Inter', system-ui, -apple-system, sans-serif;
  }

  * { box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    font-family: var(--font-body);
    color: var(--ink);
    background: var(--bg, #fff);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    line-height: 1.6;
  }

  h1, h2, h3 {
    font-family: var(--font-head);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  main {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
  }

  a { color: var(--blue); }

  ::selection { background: rgba(37, 99, 235, 0.2); }

  /* ---------- scroll reveal (progressive enhancement) ---------- */
  [data-reveal] { opacity: 1; }
  .js [data-reveal] { opacity: 0; transform: translateY(20px); }
  .js [data-reveal].is-in {
    opacity: 1; transform: none;
    transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1), transform 0.7s cubic-bezier(0.22,1,0.36,1);
  }
  @media (prefers-reduced-motion: reduce) {
    .js [data-reveal] { opacity: 1; transform: none; transition: none; }
  }

  /* ---------- buttons ---------- */
  .btn {
    display: inline-flex; align-items: center; font-weight: 600;
    padding: 0.8rem 1.6rem; border-radius: 999px; text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-primary { background: var(--grad-red); color: #fff; box-shadow: 0 10px 24px -8px rgba(232,49,42,0.7); }
  .btn-ghost { background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.25); }
  .btn-ghost-light { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.4); }
  .btn-blue { background: var(--grad-brand); color: #fff; box-shadow: 0 10px 24px -10px rgba(37,99,235,0.7); }
  .btn-outline { background: #fff; color: var(--blue); border: 1.5px solid var(--blue); }

  /* ---------- hero ---------- */
  .hero {
    position: relative; margin: 1rem 0 4rem; border-radius: var(--r-lg);
    overflow: hidden; color: #fff; isolation: isolate;
  }
  .hero-bg { position: absolute; inset: 0; background: var(--grad-hero); z-index: -1; }
  .hero-bg::after {
    content: ""; position: absolute; inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.07) 1px, transparent 1px);
    background-size: 26px 26px;
    -webkit-mask-image: radial-gradient(120% 100% at 70% 0%, #000 30%, transparent 75%);
    mask-image: radial-gradient(120% 100% at 70% 0%, #000 30%, transparent 75%);
  }
  .hero-inner {
    display: grid; grid-template-columns: 1.05fr 0.95fr; align-items: center;
    gap: 1rem; padding: clamp(2rem, 4vw, 3.5rem);
  }
  .hero-inner.solo { grid-template-columns: 1fr; text-align: center; max-width: 50rem; margin: 0 auto; }
  .eyebrow {
    display: inline-block; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; color: #9fc0ff; margin-bottom: 1rem;
  }
  .hero h1 { font-size: clamp(2.2rem, 5vw, 3.6rem); margin: 0 0 1rem; }
  .grad {
    background: linear-gradient(120deg, #7fd4ff, #ff7a6e);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .lead { font-size: 1.1rem; color: #c8d2f5; max-width: 36rem; margin: 0 0 1.75rem; }
  .hero-inner.solo .lead { margin-left: auto; margin-right: auto; }
  .hero-cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .hero-inner.solo .hero-cta, .cta .hero-cta { justify-content: center; }
  .chips { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0; margin: 1.75rem 0 0; }
  .hero-inner.solo .chips { justify-content: center; }
  .chips li {
    font-size: 0.82rem; font-weight: 500; padding: 0.45rem 0.9rem; border-radius: 999px;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.16); backdrop-filter: blur(8px);
  }
  .hero-art img { width: 100%; height: auto; display: block; filter: drop-shadow(0 30px 50px rgba(0,0,0,0.4)); }

  /* ---------- sections ---------- */
  .section { margin: 4rem 0; }
  .section-head { text-align: center; max-width: 42rem; margin: 0 auto 2.5rem; }
  .kicker { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue); }
  .section-head h2 { font-size: clamp(1.8rem, 3.5vw, 2.5rem); margin: 0.5rem 0 0; color: var(--ink); }
  .section-sub { color: var(--muted); margin: 0.75rem 0 0; }

  /* ---------- grids + cards ---------- */
  .grid-3 { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .grid-2 { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); }
  .card {
    display: block; padding: 2rem; border-radius: var(--r-lg); background: #fff;
    border: 1px solid var(--line); text-decoration: none; color: var(--ink);
    box-shadow: var(--shadow-sm);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: transparent; }
  .card-icon {
    display: inline-flex; align-items: center; justify-content: center; width: 56px; height: 56px;
    border-radius: 16px; background: var(--grad-brand); color: #fff; margin-bottom: 1.25rem;
  }
  .card h3 { font-size: 1.25rem; margin: 0 0 0.6rem; color: var(--navy); }
  .card p { color: var(--muted); margin: 0 0 1.1rem; font-size: 0.95rem; }
  .card-link { font-weight: 600; color: var(--blue); font-size: 0.92rem; }
  .arrow { transition: transform 0.15s ease; display: inline-block; }
  .card:hover .arrow, .dc-card:hover .arrow { transform: translateX(4px); }

  /* dark premium card */
  .dc-card {
    display: block; padding: 2rem; border-radius: var(--r-lg); background: var(--grad-hero);
    color: #fff; text-decoration: none; box-shadow: var(--shadow-lg); transition: transform 0.18s ease;
  }
  .dc-card:hover { transform: translateY(-6px); }
  .dc-tag {
    display: inline-block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: #fff; background: var(--grad-red);
    padding: 0.3rem 0.8rem; border-radius: 999px; margin-bottom: 1rem;
  }
  .dc-card h3 { font-size: 1.5rem; margin: 0 0 0.6rem; }
  .dc-card p { color: #c8d2f5; font-size: 0.95rem; margin: 0 0 1.1rem; }
  .dc-card .card-link { color: #7fd4ff; }

  /* numbered feature */
  .why { padding: 1.75rem; border-radius: var(--r-lg); background: var(--surface); border: 1px solid var(--line); }
  .why-num { font-family: var(--font-head); font-size: 1.6rem; font-weight: 700; color: var(--blue); opacity: 0.5; }
  .why h3 { font-size: 1.15rem; margin: 0.5rem 0 0.5rem; color: var(--navy); }
  .why p { color: var(--muted); font-size: 0.95rem; margin: 0; }

  /* soft panel + pill list */
  .panel { background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 2rem; }
  .pill-list { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0; margin: 0; }
  .pill-list li {
    font-size: 0.85rem; font-weight: 500; padding: 0.4rem 0.85rem; border-radius: 999px;
    background: #eef2ff; color: var(--blue); text-transform: capitalize;
  }

  /* faq (shared) */
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; max-width: 48rem; margin: 0 auto; }
  .faq-item { border: 1px solid var(--line); border-radius: var(--r); overflow: hidden; background: #fff; }
  .faq-item summary { padding: 1.1rem 1.4rem; cursor: pointer; font-weight: 600; color: var(--ink); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: "+"; float: right; color: var(--blue); font-weight: 700; }
  .faq-item[open] summary::after { content: "−"; }
  .faq-item p { padding: 0 1.4rem 1.1rem; margin: 0; color: var(--muted); line-height: 1.6; }

  /* ---------- CTA band ---------- */
  .cta {
    position: relative; text-align: center; padding: clamp(2.5rem, 5vw, 4rem) 1.5rem;
    border-radius: var(--r-lg); overflow: hidden; color: #fff; isolation: isolate; margin: 4rem 0 1rem;
  }
  .cta-bg { position: absolute; inset: 0; background: var(--grad-hero); z-index: -1; }
  .cta h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin: 0 0 0.6rem; color: #fff; }
  .cta p { color: #c8d2f5; margin: 0 0 1.75rem; font-size: 1.1rem; }

  /* ---------- stats bar ---------- */
  .stats-bar {
    display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    max-width: 58rem; margin: 0 auto;
  }
  .stat {
    text-align: center; padding: 1.5rem 1rem; border-radius: var(--r);
    background: var(--surface); border: 1px solid var(--line);
  }
  .stat-num {
    font-family: var(--font-head); font-size: 2rem; font-weight: 700;
    color: var(--navy); line-height: 1;
  }
  .stat-label { font-size: 0.82rem; color: var(--muted); margin-top: 0.4rem; }

  /* ---------- key takeaway (GEO-SEO) ---------- */
  .key-takeaway {
    max-width: 48rem; margin: 2rem auto; text-align: center;
  }
  .key-takeaway blockquote {
    font-size: 1.15rem; font-weight: 500; line-height: 1.7; color: var(--navy);
    background: var(--surface); border: 1px solid var(--line);
    border-left: 4px solid var(--blue); border-radius: var(--r-lg);
    padding: 1.5rem 2rem; margin: 0.75rem 0 0;
    position: relative;
  }
  .key-takeaway blockquote::before {
    content: "\201C"; font-size: 3rem; color: var(--blue); opacity: 0.25;
    position: absolute; top: 0.25rem; left: 0.75rem; line-height: 1;
  }

  /* ---------- answer block (GEO-SEO) ---------- */
  .answer-block {
    max-width: 52rem; margin: 0 auto 2.5rem;
  }
  .answer-block h3 {
    font-size: 1.25rem; color: var(--navy); margin: 0 0 0.75rem;
  }
  .answer-block p {
    color: var(--muted); line-height: 1.8; margin: 0;
  }

  /* ---------- trust bar ---------- */
  .trust-bar {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 1.25rem;
    max-width: 56rem; margin: 0 auto;
  }
  .trust-item {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.85rem; font-weight: 500; color: var(--muted);
    background: var(--surface); border: 1px solid var(--line);
    padding: 0.5rem 1rem; border-radius: 999px;
  }
  .trust-item .badge { font-weight: 700; color: var(--navy); }

  /* ---------- reviews (shared) ---------- */
  .review-grid {
    display: grid; gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    max-width: 64rem; margin: 0 auto;
  }
  .review-card {
    margin: 0; background: #fff; border: 1px solid var(--line);
    border-radius: var(--r-lg); padding: 1.5rem; box-shadow: var(--shadow-sm);
    display: flex; flex-direction: column; gap: 0.75rem;
  }
  .review-card .stars { color: #f5a623; letter-spacing: 2px; font-size: 1rem; }
  .review-card blockquote { margin: 0; color: var(--ink); line-height: 1.7; font-size: 0.95rem; flex: 1; }
  .review-card figcaption { color: var(--muted); font-size: 0.85rem; }
  .review-card figcaption strong { color: var(--navy); }

  /* ---------- benefit / included checklist (shared) ---------- */
  .benefit-list {
    list-style: none; max-width: 48rem; margin: 0 auto; padding: 0;
    display: grid; gap: 0.85rem;
  }
  .benefit-list li {
    display: flex; gap: 0.75rem; align-items: flex-start;
    background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--r); padding: 1rem 1.25rem; color: var(--ink);
    line-height: 1.6; font-size: 0.96rem;
  }
  .benefit-check {
    flex-shrink: 0; font-weight: 700; color: #fff; background: var(--grad-brand);
    width: 26px; height: 26px; border-radius: 999px;
    display: inline-flex; align-items: center; justify-content: center; font-size: 0.8rem;
  }

  /* ---------- process steps (shared) ---------- */
  .svc-process {
    display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    max-width: 64rem; margin: 0 auto;
  }
  .svc-step {
    background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg);
    padding: 1.5rem; box-shadow: var(--shadow-sm);
  }
  .svc-step-num {
    font-family: var(--font-head); font-weight: 700; font-size: 1.4rem;
    color: var(--blue); display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 12px; background: #eef2ff; margin-bottom: 0.75rem;
  }
  .svc-step h3 { font-size: 1.05rem; margin: 0 0 0.4rem; color: var(--navy); }
  .svc-step p { margin: 0; color: var(--muted); font-size: 0.92rem; line-height: 1.6; }

  /* ---------- owner note callout (shared) ---------- */
  .owner-note {
    max-width: 52rem; margin: 0 auto; background: var(--grad-hero); color: #fff;
    border-radius: var(--r-lg); padding: 2rem 2.25rem; box-shadow: var(--shadow-lg);
  }
  .owner-note p { margin: 0; font-size: 1.1rem; line-height: 1.7; font-style: italic; }
  .owner-note cite { display: block; margin-top: 0.9rem; font-style: normal; font-weight: 600; color: #9fc0ff; font-size: 0.9rem; }

  @media (max-width: 860px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-art { order: -1; max-width: 460px; margin: 0 auto; }
  }
</style>
